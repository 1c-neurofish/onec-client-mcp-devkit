
#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура КомандаВопрос(Команда)
	ПоказатьВопрос(Новый ОписаниеОповещения("ОбработатьОтветВопрос", ЭтотОбъект),
		"Вы подтверждаете действие?", РежимДиалогаВопрос.ДаНет);
КонецПроцедуры

&НаКлиенте
Процедура КомандаПредупреждение(Команда)
	ПоказатьПредупреждение(Новый ОписаниеОповещения("ОбработатьОтветПредупреждение", ЭтотОбъект),
		"Это предупреждение для тестирования.");
КонецПроцедуры

&НаКлиенте
Процедура КомандаВвестиСтроку(Команда)
	ВводимаяСтрока = "";
	ПоказатьВводСтроки(Новый ОписаниеОповещения("ОбработатьВводСтроки", ЭтотОбъект),
		ВводимаяСтрока, "Введите значение");
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьДочернююФорму(Команда)
	ПараметрыФормы = Новый Структура;
	ОткрытьФорму("Обработка.МодальныеДиалоги.Форма.ДочерняяФорма",
		ПараметрыФормы, ЭтотОбъект, , , ,
		Новый ОписаниеОповещения("ОбработатьЗакрытиеДочернейФормы", ЭтотОбъект),
		"БлокироватьВесьИнтерфейс");
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОбработатьОтветВопрос(Результат, ДополнительныеПараметры) Экспорт
	Если Результат = КодВозвратаДиалога.Да Тогда
		ТекстОтвета = "Да";
	ИначеЕсли Результат = КодВозвратаДиалога.Нет Тогда
		ТекстОтвета = "Нет";
	Иначе
		ТекстОтвета = "Отмена";
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьОтветПредупреждение(ДополнительныеПараметры) Экспорт
	ТекстОтвета = "ОК";
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьВводСтроки(Текст, ДополнительныеПараметры) Экспорт
	Если Текст = Неопределено Тогда
		ТекстОтвета = "Отмена";
	Иначе
		ТекстОтвета = Текст;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьЗакрытиеДочернейФормы(Результат, ДополнительныеПараметры) Экспорт
	Если Результат = Неопределено Тогда
		ТекстОтвета = "Отмена";
	Иначе
		ТекстОтвета = Результат;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти
