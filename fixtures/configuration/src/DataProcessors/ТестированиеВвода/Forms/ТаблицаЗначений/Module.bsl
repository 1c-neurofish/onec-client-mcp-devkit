
#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ЗаполнитьТаблицу(Команда)
	Таблица.Очистить();

	НоваяСтрока = Таблица.Добавить();
	НоваяСтрока.Строка  = "Первая строка";
	НоваяСтрока.Число   = 100;
	НоваяСтрока.Дата    = '20240101';
	НоваяСтрока.Активен = Истина;

	НоваяСтрока = Таблица.Добавить();
	НоваяСтрока.Строка  = "Вторая строка";
	НоваяСтрока.Число   = 200.50;
	НоваяСтрока.Дата    = '20240615';
	НоваяСтрока.Активен = Ложь;

	НоваяСтрока = Таблица.Добавить();
	НоваяСтрока.Строка  = "Третья строка";
	НоваяСтрока.Число   = 300.99;
	НоваяСтрока.Дата    = '20241231';
	НоваяСтрока.Активен = Истина;
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьТаблицу(Команда)
	Таблица.Очистить();
КонецПроцедуры

#КонецОбласти
