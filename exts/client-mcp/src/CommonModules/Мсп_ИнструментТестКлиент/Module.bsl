//
// Возвращаемое значение:
//  Произвольный - Результат инструмента.
Функция ОбработчикКомандыВвода(Запрос, ДополнительныеПараметры) Экспорт
	Аргументы = АргументыИнструмента(Запрос);
	РезультатURI = СтроковыйАргумент(Аргументы, "uri", Истина);
	ОшибкаИнструмента = РезультатОшибкиИнструмента(РезультатURI);
	Если ОшибкаИнструмента <> Неопределено Тогда
		Возврат ОшибкаИнструмента;
	КонецЕсли;
	РезультатТекста = СтроковыйАргумент(Аргументы, "text", Истина);
	ОшибкаИнструмента = РезультатОшибкиИнструмента(РезультатТекста);
	Если ОшибкаИнструмента <> Неопределено Тогда
		Возврат ОшибкаИнструмента;
	КонецЕсли;

	РезультатВвода = Мсп_ФормыКлиент.ВвестиТекстПоURI(РезультатURI.Значение, РезультатТекста.Значение);
	ОшибкаИнструмента = РезультатОшибкиИнструмента(РезультатВвода);
	Если ОшибкаИнструмента <> Неопределено Тогда
