	Возврат НовыйРезультатИнструмента(РезультатВвода.Успех, РезультатВвода.Данные);
КонецФункции

// Выполняет выбор значения в поле формы по URI.
//
// Параметры:
//  Запрос - Структура - Запрос инструмента:
//   * Аргументы - Структура - Аргументы вызова.
//   * Контекст - Структура - Контекст вызова.
//  ДополнительныеПараметры - Произвольный - Дополнительные параметры вызова.
//
// Возвращаемое значение:
//  Произвольный - Результат инструмента.
Функция ОбработчикКомандыВыбора(Запрос, ДополнительныеПараметры) Экспорт
	Аргументы = АргументыИнструмента(Запрос);
	РезультатURI = СтроковыйАргумент(Аргументы, "uri", Истина);
	ОшибкаИнструмента = РезультатОшибкиИнструмента(РезультатURI);
	Если ОшибкаИнструмента <> Неопределено Тогда
		Возврат ОшибкаИнструмента;
	КонецЕсли;

	ЕстьValue = ЕстьАргумент(Аргументы, "value");
	ЕстьIndex = ЕстьАргумент(Аргументы, "index");
	Если ЕстьValue = ЕстьIndex Тогда
		Возврат НовыйРезультатОшибкиИнструмента("INVALID_PARAMS", "exactly one of value or index is required");
	КонецЕсли;

	РезультатValue = СтроковыйАргумент(Аргументы, "value");
	ОшибкаИнструмента = РезультатОшибкиИнструмента(РезультатValue);
	Если ОшибкаИнструмента <> Неопределено Тогда
		Возврат ОшибкаИнструмента;
	КонецЕсли;
	РезультатIndex = ЧисловойАргумент(Аргументы, "index", 0);
	ОшибкаИнструмента = РезультатОшибкиИнструмента(РезультатIndex);
	Если ОшибкаИнструмента <> Неопределено Тогда
		Возврат ОшибкаИнструмента;
	КонецЕсли;

	РезультатВыбора = Мсп_ФормыКлиент.ВыбратьПоURI(
		РезультатURI.Значение,
		РезультатValue.Значение,
		РезультатIndex.Значение,
		ЕстьIndex);
	ОшибкаИнструмента = РезультатОшибкиИнструмента(РезультатВыбора);
	Если ОшибкаИнструмента <> Неопределено Тогда
		Возврат ОшибкаИнструмента;
	КонецЕсли;

	Возврат НовыйРезультатИнструмента(РезультатВыбора.Успех, РезультатВыбора.Данные);
КонецФункции

