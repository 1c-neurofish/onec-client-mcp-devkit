// Открывает форму через ExecuteCommand активного окна.
//
// Параметры:
//  Запрос - Структура - Запрос инструмента:
//   * Аргументы - Структура - Аргументы вызова.
//   * Контекст - Структура - Контекст вызова.
//  ДополнительныеПараметры - Произвольный - Дополнительные параметры вызова.
//
// Возвращаемое значение:
//  Произвольный - Результат инструмента.
Функция ОбработчикКомандыОткрытияФормы(Запрос, ДополнительныеПараметры) Экспорт
	Аргументы = АргументыИнструмента(Запрос);
	РезультатTarget = СтроковыйАргумент(Аргументы, "target", Истина);
	ОшибкаИнструмента = РезультатОшибкиИнструмента(РезультатTarget);
	Если ОшибкаИнструмента <> Неопределено Тогда
		Возврат ОшибкаИнструмента;
	КонецЕсли;

	РезультатОткрытия = Мсп_ФормыКлиент.ОткрытьФормуПоКоманде(РезультатTarget.Значение);
	ОшибкаИнструмента = РезультатОшибкиИнструмента(РезультатОткрытия);
	Если ОшибкаИнструмента <> Неопределено Тогда
		Возврат ОшибкаИнструмента;
	КонецЕсли;

	Возврат НовыйРезультатИнструмента(РезультатОткрытия.Успех, НовыйДанныеОткрытияФормы(
		РезультатОткрытия.Target,
		РезультатОткрытия.WindowURI,
		РезультатОткрытия.FormURI));
КонецФункции

