#Область ПрограммныйИнтерфейс

// Регистрирует провайдеров MCP из подсистемы Мсп_Провайдеры.
Процедура ЗарегистрироватьПровайдеров() Экспорт
	Мсп_РеестрКлиент.ИнициализироватьРеестры();
	
	ОписаниеПровайдеров = Мсп_МетаданныеВызовСервера.Провайдеры();
	
	Для Каждого ОписаниеПровайдера Из ОписаниеПровайдеров Цикл
		ЗарегистрироватьПровайдера(ОписаниеПровайдера);
	КонецЦикла;
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ЗарегистрироватьПровайдера(ОписаниеПровайдера)
	
	МодульПровайдера = МодульПровайдера(ОписаниеПровайдера);
	Если МодульПровайдера = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Попытка
		ОписанияИнструментов = МодульПровайдера.ОписаниеИнструментов();
		ЗарегистрироватьИнструменты(ОписанияИнструментов, МодульПровайдера);
	Исключение
		ОбработатьОшибкуОпциональногоМетода(ИнформацияОбОшибке(), "ОписаниеИнструментов");
	КонецПопытки;
	
	Попытка
		ОписанияРесурсов = МодульПровайдера.ОписаниеРесурсов();
		ЗарегистрироватьРесурсы(ОписанияРесурсов, МодульПровайдера);
	Исключение
		ОбработатьОшибкуОпциональногоМетода(ИнформацияОбОшибке(), "ОписаниеРесурсов");
	КонецПопытки;
	
	Попытка
		ОписанияПромптов = МодульПровайдера.ОписаниеПромптов();
		ЗарегистрироватьПромпты(ОписанияПромптов, МодульПровайдера);
	Исключение
		ОбработатьОшибкуОпциональногоМетода(ИнформацияОбОшибке(), "ОписаниеПромптов");
	КонецПопытки;
КонецПроцедуры

Функция МодульПровайдера(ОписаниеПровайдера)
	
	Если ОписаниеПровайдера.Тип <> "ОбщийМодуль" Тогда
		Мсп_ЛогированиеКлиент.Ошибка(СтрШаблон("Провайдер с типом '%1' не поддерживается", ОписаниеПровайдера.Тип));
		Возврат Неопределено;
	КонецЕсли;
	
	Попытка
		Возврат Вычислить(ОписаниеПровайдера.Имя);
	Исключение
		Мсп_ЛогированиеКлиент.Ошибка(СтрШаблон("Не удалось создать провайдер '%1' с типом '%2'",
			ОписаниеПровайдера.Имя, ОписаниеПровайдера.Тип));
	КонецПопытки;
	
	Возврат Неопределено;
КонецФункции

Процедура ЗарегистрироватьИнструменты(Описания, МодульПровайдера)
	Если ТипЗнч(Описания) <> Тип("Массив") Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого Описание Из Описания Цикл
		Попытка
			Мсп_ПротоколКлиент.ЗарегистрироватьИнструмент(Описание.Имя, Описание.Описание, Описание.СхемаJSON, Описание.Оповещение);
		Исключение
			ОбработатьОшибку(ИнформацияОбОшибке());
		КонецПопытки;
	КонецЦикла;
КонецПроцедуры

Процедура ЗарегистрироватьРесурсы(Описания, МодульПровайдера)
	Для Каждого Описание Из Описания Цикл
		Мсп_ПротоколКлиент.ЗарегистрироватьРесурс(Описание.URI, Описание.Описание, Описание.MimeType, Описание.Оповещение);
	КонецЦикла;
КонецПроцедуры

Процедура ЗарегистрироватьПромпты(Описания, МодульПровайдера)
	Для Каждого Описание Из Описания Цикл
		Попытка
			Мсп_ПротоколКлиент.ЗарегистрироватьПромпт(Описание.Имя, Описание.Описание, Описание.Аргументы, Описание.Оповещение);
		Исключение
			ОбработатьОшибку(ИнформацияОбОшибке());
		КонецПопытки;
	КонецЦикла;
КонецПроцедуры

Процедура ОбработатьОшибкуОпциональногоМетода(Ошибка, ИмяМетода) Экспорт
	
	Если Ошибка.Описание = СтрШаблон("Метод объекта не обнаружен (%1)", ИмяМетода) Тогда
		Возврат;
	КонецЕсли;
	
	ОбработатьОшибку(Ошибка);
	
КонецПроцедуры

Процедура ОбработатьОшибку(ДанныеОшибки)
	Мсп_ЛогированиеКлиент.Ошибка(ОбработкаОшибок.ПодробноеПредставлениеОшибки(ДанныеОшибки));
КонецПроцедуры

#КонецОбласти
