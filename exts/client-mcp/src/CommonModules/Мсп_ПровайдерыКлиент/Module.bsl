#Область ПрограммныйИнтерфейс

// Регистрирует провайдеров MCP из подсистемы Мсп_Провайдеры.
Процедура ЗарегистрироватьПровайдеров() Экспорт
	ОписаниеПровайдеров = Мсп_МетаданныеВызовСервера.Провайдеры();
	
	Для Каждого ОписаниеПровайдера Из ОписаниеПровайдеров Цикл
		ЗарегистрироватьПровайдера(ОписаниеПровайдера);
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ЗарегистрироватьПровайдера(ОписаниеПровайдера)
	
	Мсп_ЛогированиеКлиент.Информация("Регистрация провайдера %1.%2", ОписаниеПровайдера.Тип, ОписаниеПровайдера.Имя);
	МодульПровайдера = МодульПровайдера(ОписаниеПровайдера);
	Если МодульПровайдера = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Если ВыполнитьРегистрациюПровайдераV2(МодульПровайдера, ОписаниеПровайдера.Имя) Тогда
		Возврат;
	КонецЕсли;
	
	СнимокРеестров = НовыйСнимокРеестров();
	Попытка
		МодульПровайдера.ЗарегистрироватьИнструменты();
	Исключение
		ОбработатьОшибкуОпциональногоМетода(ИнформацияОбОшибке(), "ЗарегистрироватьИнструменты");
	КонецПопытки;
	ПроставитьИсточникРегистрацииНовымЗаписям(СнимокРеестров, ОписаниеПровайдера.Имя);
	
	СнимокРеестров = НовыйСнимокРеестров();
	Попытка
		МодульПровайдера.ЗарегистрироватьРесурсы();
	Исключение
		ОбработатьОшибкуОпциональногоМетода(ИнформацияОбОшибке(), "ЗарегистрироватьРесурсы");
	КонецПопытки;
	ПроставитьИсточникРегистрацииНовымЗаписям(СнимокРеестров, ОписаниеПровайдера.Имя);
	
	СнимокРеестров = НовыйСнимокРеестров();
	Попытка
		МодульПровайдера.ЗарегистрироватьПромпты();
	Исключение
		ОбработатьОшибкуОпциональногоМетода(ИнформацияОбОшибке(), "ЗарегистрироватьПромпты");
	КонецПопытки;
	ПроставитьИсточникРегистрацииНовымЗаписям(СнимокРеестров, ОписаниеПровайдера.Имя);
КонецПроцедуры

Функция МодульПровайдера(ОписаниеПровайдера)
	
	Если ОписаниеПровайдера.Тип <> "ОбщийМодуль" Тогда
		Мсп_ЛогированиеКлиент.Ошибка("Провайдер с типом '%1' не поддерживается", ОписаниеПровайдера.Тип);
		Возврат Неопределено;
	КонецЕсли;
	
	Попытка
		Возврат Вычислить(ОписаниеПровайдера.Имя);
	Исключение
		Мсп_ЛогированиеКлиент.Ошибка("Не удалось создать провайдер '%1' с типом '%2'",
			ОписаниеПровайдера.Имя, ОписаниеПровайдера.Тип);
	КонецПопытки;
	
	Возврат Неопределено;
КонецФункции

Процедура ОбработатьОшибкуОпциональногоМетода(Ошибка, ИмяМетода) Экспорт
	
	Если ЭтоОшибкаОтсутствующегоОпциональногоМетода(Ошибка.Описание, ИмяМетода) Тогда
		Возврат;
	КонецЕсли;
	
	Мсп_ЛогированиеКлиент.Ошибка(Ошибка);
	
КонецПроцедуры

Функция ЭтоОшибкаОтсутствующегоОпциональногоМетода(ОписаниеОшибки, ИмяМетода)
	
	Возврат СтрНайти(ОписаниеОшибки, СтрШаблон("Метод объекта не обнаружен (%1)", ИмяМетода)) > 0
		Или СтрНайти(ОписаниеОшибки, СтрШаблон("Object method not found (%1)", ИмяМетода)) > 0;
	
КонецФункции

Функция ВыполнитьРегистрациюПровайдераV2(МодульПровайдера, ИсточникРегистрации)
	Попытка
		МодульПровайдера.Зарегистрировать(ИсточникРегистрации);
		Возврат Истина;
	Исключение
		Ошибка = ИнформацияОбОшибке();
		Если ЭтоОшибкаОтсутствующегоОпциональногоМетода(Ошибка.Описание, "Зарегистрировать") Тогда
			Возврат Ложь;
		КонецЕсли;

		Мсп_ЛогированиеКлиент.Ошибка(Ошибка);
	КонецПопытки;

	Возврат Истина;
КонецФункции

Функция НовыйСнимокРеестров()
	Снимок = Новый Структура;
	Снимок.Вставить("Инструменты", СнимокКлючейРеестра(Мсп_РеестрКлиент.РеестрИнструментов()));
	Снимок.Вставить("Ресурсы", СнимокКлючейРеестра(Мсп_РеестрКлиент.РеестрРесурсов()));
	Снимок.Вставить("ШаблоныРесурсов", СнимокКлючейРеестра(Мсп_РеестрКлиент.РеестрШаблоновРесурсов()));
	Снимок.Вставить("Промпты", СнимокКлючейРеестра(Мсп_РеестрКлиент.РеестрПромптов()));
	Возврат Снимок;
КонецФункции

Функция СнимокКлючейРеестра(Реестр)
	Ключи = Новый Соответствие;
	Для Каждого Элемент Из Реестр Цикл
		Ключи.Вставить(Элемент.Ключ, Истина);
	КонецЦикла;
	Возврат Ключи;
КонецФункции

Процедура ПроставитьИсточникРегистрацииНовымЗаписям(СнимокРеестров, ИсточникРегистрации)
	ПроставитьИсточникРегистрацииНовымЗаписямРеестра(
		Мсп_РеестрКлиент.РеестрИнструментов(),
		СнимокРеестров.Инструменты,
		ИсточникРегистрации);
	ПроставитьИсточникРегистрацииНовымЗаписямРеестра(
		Мсп_РеестрКлиент.РеестрРесурсов(),
		СнимокРеестров.Ресурсы,
		ИсточникРегистрации);
	ПроставитьИсточникРегистрацииНовымЗаписямРеестра(
		Мсп_РеестрКлиент.РеестрШаблоновРесурсов(),
		СнимокРеестров.ШаблоныРесурсов,
		ИсточникРегистрации);
	ПроставитьИсточникРегистрацииНовымЗаписямРеестра(
		Мсп_РеестрКлиент.РеестрПромптов(),
		СнимокРеестров.Промпты,
		ИсточникРегистрации);
КонецПроцедуры

Процедура ПроставитьИсточникРегистрацииНовымЗаписямРеестра(Реестр, КлючиДоРегистрации, ИсточникРегистрации)
	Для Каждого Элемент Из Реестр Цикл
		Если Не КлючиДоРегистрации.СодержитКлюч(Элемент.Ключ)
			И ТипЗнч(Элемент.Значение) = Тип("Структура") Тогда
			Элемент.Значение.Вставить("ИсточникРегистрации", ИсточникРегистрации);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

#КонецОбласти
