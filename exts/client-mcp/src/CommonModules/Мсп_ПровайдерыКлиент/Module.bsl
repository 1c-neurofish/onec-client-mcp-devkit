#Область ПрограммныйИнтерфейс

// Регистрирует провайдеров MCP из подсистемы Мсп_Провайдеры.
Процедура ЗарегистрироватьПровайдеров() Экспорт
	Мсп_ИнструментыКлиент.ИнициализироватьРеестры();
	Подсистема = Метаданные.Подсистемы.Найти("Мсп_Провайдеры");
	Если Подсистема = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Для Каждого МетаданныеМодуля Из Подсистема.Состав Цикл
		ЗарегистрироватьПровайдера(МетаданныеМодуля);
	КонецЦикла;
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ЗарегистрироватьПровайдера(МетаданныеМодуля)
	Если МетаданныеМодуля = Неопределено Тогда
		Возврат;
	КонецЕсли;

	ИмяМодуля = МетаданныеМодуля.Имя;
	Если Не ЗначениеЗаполнено(ИмяМодуля) Тогда
		Возврат;
	КонецЕсли;

	МодульПровайдера = ПолучитьМодульПровайдера(ИмяМодуля);
	Если МодульПровайдера = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Попытка
		ОписанияИнструментов = МодульПровайдера.ОписаниеИнструментов();
		ЗарегистрироватьИнструменты(ОписанияИнструментов, МодульПровайдера);
	Исключение
		ИгнорироватьОшибку();
	КонецПопытки;

	Попытка
		ОписанияРесурсов = МодульПровайдера.ОписаниеРесурсов();
		ЗарегистрироватьРесурсы(ОписанияРесурсов, МодульПровайдера);
	Исключение
		ИгнорироватьОшибку();
	КонецПопытки;

	Попытка
		ОписанияПромптов = МодульПровайдера.ОписаниеПромптов();
		ЗарегистрироватьПромпты(ОписанияПромптов, МодульПровайдера);
	Исключение
		ИгнорироватьОшибку();
	КонецПопытки;
КонецПроцедуры

Функция ПолучитьМодульПровайдера(ИмяМодуля)
	Если Не ЗначениеЗаполнено(ИмяМодуля) Тогда
		Возврат Неопределено;
	КонецЕсли;

	МодульПровайдера = Неопределено;
	Попытка
#Если ТонкийКлиент Тогда
		Выполнить("МодульПровайдера = " + ИмяМодуля);
#ИначеЕсли НЕ ВебКлиент Тогда
		УстановитьБезопасныйРежим(Истина);
		Попытка
			Выполнить("МодульПровайдера = " + ИмяМодуля);
		Исключение
			УстановитьБезопасныйРежим(Ложь);
			ВызватьИсключение;
		КонецПопытки;
		УстановитьБезопасныйРежим(Ложь);
#КонецЕсли
	Исключение
		МодульПровайдера = Неопределено;
	КонецПопытки;

	Возврат МодульПровайдера;
КонецФункции

Процедура ЗарегистрироватьИнструменты(Описания, МодульПровайдера)
	Если ТипЗнч(Описания) <> Тип("Массив") Тогда
		Возврат;
	КонецЕсли;

	Для Каждого Описание Из Описания Цикл
		Попытка
			Имя = Мсп_ИнструментыКлиент.ПолучитьСвойство(Описание, "Имя", "");
			ИмяМетода = Мсп_ИнструментыКлиент.ПолучитьСвойство(Описание, "Метод", "");
			Если Не ЗначениеЗаполнено(Имя) Или Не ЗначениеЗаполнено(ИмяМетода) Тогда
				Продолжить;
			КонецЕсли;

			ОписаниеИнструмента = Мсп_ИнструментыКлиент.ПолучитьСвойство(Описание, "Описание", "");
			СхемаJSON = Мсп_ИнструментыКлиент.ПолучитьСвойство(Описание, "СхемаJSON", Неопределено);
			Обработчик = Новый ОписаниеОповещения(ИмяМетода, МодульПровайдера);
			Мсп_ИнструментыКлиент.ЗарегистрироватьИнструмент(Имя, ОписаниеИнструмента, СхемаJSON, Обработчик);
		Исключение
			ИгнорироватьОшибку();
		КонецПопытки;
	КонецЦикла;
КонецПроцедуры

Процедура ЗарегистрироватьРесурсы(Описания, МодульПровайдера)
	Если ТипЗнч(Описания) <> Тип("Массив") Тогда
		Возврат;
	КонецЕсли;

	Для Каждого Описание Из Описания Цикл
		Попытка
			URI = Мсп_ИнструментыКлиент.ПолучитьСвойство(Описание, "URI", "");
			ИмяМетода = Мсп_ИнструментыКлиент.ПолучитьСвойство(Описание, "Метод", "");
			Если Не ЗначениеЗаполнено(URI) Или Не ЗначениеЗаполнено(ИмяМетода) Тогда
				Продолжить;
			КонецЕсли;

			ОписаниеРесурса = Мсп_ИнструментыКлиент.ПолучитьСвойство(Описание, "Описание", "");
			MimeType = Мсп_ИнструментыКлиент.ПолучитьСвойство(Описание, "MimeType", "");
			Обработчик = Новый ОписаниеОповещения(ИмяМетода, МодульПровайдера);
			Мсп_ИнструментыКлиент.ЗарегистрироватьРесурс(URI, ОписаниеРесурса, MimeType, Обработчик);
		Исключение
			ИгнорироватьОшибку();
		КонецПопытки;
	КонецЦикла;
КонецПроцедуры

Процедура ЗарегистрироватьПромпты(Описания, МодульПровайдера)
	Если ТипЗнч(Описания) <> Тип("Массив") Тогда
		Возврат;
	КонецЕсли;

	Для Каждого Описание Из Описания Цикл
		Попытка
			Имя = Мсп_ИнструментыКлиент.ПолучитьСвойство(Описание, "Имя", "");
			ИмяМетода = Мсп_ИнструментыКлиент.ПолучитьСвойство(Описание, "Метод", "");
			Если Не ЗначениеЗаполнено(Имя) Или Не ЗначениеЗаполнено(ИмяМетода) Тогда
				Продолжить;
			КонецЕсли;

			ОписаниеПромпта = Мсп_ИнструментыКлиент.ПолучитьСвойство(Описание, "Описание", "");
			Аргументы = Мсп_ИнструментыКлиент.ПолучитьСвойство(Описание, "Аргументы", Новый Структура);
			Обработчик = Новый ОписаниеОповещения(ИмяМетода, МодульПровайдера);
			Мсп_ИнструментыКлиент.ЗарегистрироватьПромпт(Имя, ОписаниеПромпта, Аргументы, Обработчик);
		Исключение
			ИгнорироватьОшибку();
		КонецПопытки;
	КонецЦикла;
КонецПроцедуры

Процедура ИгнорироватьОшибку()
	ДанныеОшибки = ИнформацияОбОшибке();
	Если ДанныеОшибки = Неопределено Тогда
		Возврат;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти
