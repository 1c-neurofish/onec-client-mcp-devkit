#Область ПрограммныйИнтерфейс

// Регистрирует ресурсы тест-клиента MCP.
Процедура ЗарегистрироватьРесурсы() Экспорт
	Мсп_РеестрКлиент.ЗарегистрироватьРесурс(НовыйОписаниеРесурса(
		"window://active",
		"Активное окно",
		"Снимок активного окна тест-клиента",
		Новый ОписаниеОповещения("ОбработатьРесурсОкна", Мсп_РесурсыТестКлиент)));
	Мсп_РеестрКлиент.ЗарегистрироватьШаблонРесурса(НовыйОписаниеШаблонаРесурса(
		"window://{path}",
		"Окно",
		"Снимок окна тест-клиента по навигационной ссылке",
		Новый ОписаниеОповещения("ОбработатьРесурсОкна", Мсп_РесурсыТестКлиент)));
	Мсп_РеестрКлиент.ЗарегистрироватьШаблонРесурса(НовыйОписаниеШаблонаРесурса(
		"form://{name}",
		"Форма",
		"Снимок формы тест-клиента по имени формы",
		Новый ОписаниеОповещения("ОбработатьРесурсФормы", Мсп_РесурсыТестКлиент)));
КонецПроцедуры

// Возвращает снимок окна.
//
// Параметры:
//  Запрос - Структура - Запрос ресурса:
//   * Аргументы - Структура - Аргументы вызова.
//   * Контекст - Структура - Контекст вызова.
//  ДополнительныеПараметры - Произвольный - Дополнительные параметры вызова.
//
// Возвращаемое значение:
//  Структура - Результат чтения ресурса.
Функция ОбработатьРесурсОкна(Запрос, ДополнительныеПараметры) Экспорт
	URI = URIЗапроса(Запрос);
	РезультатОкна = Мсп_ОкнаКлиент.ПолучитьОкноПоURI(URI);
	Если ЗначениеЗаполнено(РезультатОкна.КодОшибки) Тогда
		Мсп_ЛогированиеКлиент.Ошибка("Window resource error uri=%1 code=%2 details=%3", URI, РезультатОкна.КодОшибки, РезультатОкна.Ошибка);
		Возврат НовыйРезультатОшибкиРесурса(РезультатОкна.КодОшибки, РезультатОкна.Ошибка);
	КонецЕсли;
	Если РезультатОкна.Окно = Неопределено Тогда
		Мсп_ЛогированиеКлиент.Ошибка("Window resource error uri=%1: window is undefined", URI);
		Возврат НовыйРезультатОшибкиРесурса("ACTION_FAILED", "window is undefined");
	КонецЕсли;

	Снимок = Мсп_ОкнаКлиент.СформироватьСнимокОкна(РезультатОкна.Окно);
	Если Снимок = Неопределено Тогда
		Мсп_ЛогированиеКлиент.Ошибка("Window resource error uri=%1: snapshot is undefined", URI);
		Возврат НовыйРезультатОшибкиРесурса("ACTION_FAILED", "window snapshot is undefined");
	КонецЕсли;
	Возврат СформироватьРезультатРесурса(URI, Снимок);
КонецФункции

// Возвращает снимок формы.
//
// Параметры:
//  Запрос - Структура - Запрос ресурса:
//   * Аргументы - Структура - Аргументы вызова.
//   * Контекст - Структура - Контекст вызова.
//  ДополнительныеПараметры - Произвольный - Дополнительные параметры вызова.
//
// Возвращаемое значение:
//  Структура - Результат чтения ресурса.
Функция ОбработатьРесурсФормы(Запрос, ДополнительныеПараметры) Экспорт
	URI = URIЗапроса(Запрос);
	РезультатФормы = Мсп_ФормыКлиент.ПолучитьФормуПоURI(URI);
	Если ЗначениеЗаполнено(РезультатФормы.КодОшибки) Тогда
		Мсп_ЛогированиеКлиент.Ошибка("Form resource error uri=%1 code=%2 details=%3", URI, РезультатФормы.КодОшибки, РезультатФормы.Ошибка);
		Возврат НовыйРезультатОшибкиРесурса(РезультатФормы.КодОшибки, РезультатФормы.Ошибка);
	КонецЕсли;
	Если РезультатФормы.Объект = Неопределено Тогда
		Мсп_ЛогированиеКлиент.Ошибка("Form resource error uri=%1: form is undefined", URI);
		Возврат НовыйРезультатОшибкиРесурса("ACTION_FAILED", "form is undefined");
	КонецЕсли;

	Снимок = Мсп_ФормыКлиент.СформироватьСнимокФормы(РезультатФормы.Объект);
	Если Снимок = Неопределено Тогда
		Мсп_ЛогированиеКлиент.Ошибка("Form resource error uri=%1: snapshot is undefined", URI);
		Возврат НовыйРезультатОшибкиРесурса("ACTION_FAILED", "form snapshot is undefined");
	КонецЕсли;

	Возврат СформироватьРезультатРесурса(URI, Снимок);
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция НовыйОписаниеРесурса(URI, Имя, Описание, Обработчик)
	ОписаниеРесурса = Мсп_РеестрКлиент.НовыйОписаниеРесурса();
	ОписаниеРесурса.URI = URI;
	ОписаниеРесурса.Имя = Имя;
	ОписаниеРесурса.Описание = Описание;
	ОписаниеРесурса.MimeType = "application/json";
	ОписаниеРесурса.Обработчик = Обработчик;
	Возврат ОписаниеРесурса;
КонецФункции

Функция НовыйОписаниеШаблонаРесурса(URIШаблон, Имя, Описание, Обработчик)
	ОписаниеШаблонаРесурса = Мсп_РеестрКлиент.НовыйОписаниеШаблонаРесурса();
	ОписаниеШаблонаРесурса.URIШаблон = URIШаблон;
	ОписаниеШаблонаРесурса.Имя = Имя;
	ОписаниеШаблонаРесурса.Описание = Описание;
	ОписаниеШаблонаРесурса.MimeType = "application/json";
	ОписаниеШаблонаРесурса.Обработчик = Обработчик;
	Возврат ОписаниеШаблонаРесурса;
КонецФункции

Функция СформироватьРезультатРесурса(URI, Данные)
	ТекстJSON = СериализоватьДанные(Данные);
	Если ТекстJSON = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	Контент = Новый Структура("uri,text,mimeType", URI, ТекстJSON, "application/json");
	МассивКонтента = Новый Массив;
	МассивКонтента.Добавить(Контент);
	Возврат Новый Структура("contents", МассивКонтента);
КонецФункции

Функция СериализоватьДанные(Данные)
	Попытка
		Возврат Мсп_СериализацияКлиент.Сериализовать(Данные);
	Исключение
		Мсп_ЛогированиеКлиент.Ошибка(ИнформацияОбОшибке());
	КонецПопытки;
	Возврат Неопределено;
КонецФункции

Функция URIЗапроса(Запрос)
	Если Запрос = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	Возврат Мсп_Коллекции.ПолучитьСвойство(Запрос.Контекст, "uri", "");
КонецФункции

Функция НовыйРезультатОшибкиРесурса(КодОшибки, Ошибка)
	Возврат Новый Структура("КодОшибки,Ошибка", КодОшибки, Ошибка);
КонецФункции

#КонецОбласти
