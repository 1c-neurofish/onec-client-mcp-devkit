#Область ПрограммныйИнтерфейс

// Инициализирует реестры MCP в состоянии клиента.
Процедура MCP_ИнициализироватьРеестры() Экспорт
	MCP_ПолучитьРеестр("MCP_Инструменты");
	MCP_ПолучитьРеестр("MCP_Ресурсы");
	MCP_ПолучитьРеестр("MCP_Промпты");
	MCP_ПолучитьРеестр("MCP_Сессии");
КонецПроцедуры

// Регистрирует инструмент и обработчик его вызова.
//
// Параметры:
//  Имя - Строка - Имя инструмента.
//  Описание - Строка - Описание инструмента.
//  СхемаJSON - Строка - JSON-схема входных параметров.
//  Оповещение - ОписаниеОповещения - Описание оповещения для вызова инструмента.
Процедура MCP_ЗарегистрироватьИнструмент(Имя, Описание, СхемаJSON, Оповещение) Экспорт
	MCP_ИнициализироватьРеестры();
	Если Не ЗначениеЗаполнено(Имя) Тогда
		ВызватьИсключение "Имя инструмента не задано.";
	КонецЕсли;
	Данные = Новый Структура;
	Данные.Вставить("name", Имя);
	Данные.Вставить("description", Описание);
	Данные.Вставить("inputSchema", СхемаJSON);
	Данные.Вставить("notify", Оповещение);
	Инструменты = MCP_ПолучитьРеестр("MCP_Инструменты");
	Инструменты.Вставить(Имя, Данные);
КонецПроцедуры

// Регистрирует ресурс и обработчик чтения.
//
// Параметры:
//  URI - Строка - Идентификатор ресурса.
//  Описание - Строка - Описание ресурса.
//  MimeType - Строка - MIME-тип ресурса.
//  Оповещение - ОписаниеОповещения - Описание оповещения для чтения ресурса.
Процедура MCP_ЗарегистрироватьРесурс(URI, Описание, MimeType, Оповещение) Экспорт
	MCP_ИнициализироватьРеестры();
	Если Не ЗначениеЗаполнено(URI) Тогда
		ВызватьИсключение "URI ресурса не задан.";
	КонецЕсли;
	Данные = Новый Структура;
	Данные.Вставить("uri", URI);
	Данные.Вставить("name", URI);
	Данные.Вставить("description", Описание);
	Данные.Вставить("mimeType", MimeType);
	Данные.Вставить("notify", Оповещение);
	Ресурсы = MCP_ПолучитьРеестр("MCP_Ресурсы");
	Ресурсы.Вставить(URI, Данные);
КонецПроцедуры

// Регистрирует промпт и обработчик получения.
//
// Параметры:
//  Имя - Строка - Имя промпта.
//  Описание - Строка - Описание промпта.
//  Аргументы - Структура - Описание аргументов промпта.
//  Оповещение - ОписаниеОповещения - Описание оповещения для получения промпта.
Процедура MCP_ЗарегистрироватьПромпт(Имя, Описание, Аргументы, Оповещение) Экспорт
	MCP_ИнициализироватьРеестры();
	Если Не ЗначениеЗаполнено(Имя) Тогда
		ВызватьИсключение "Имя промпта не задано.";
	КонецЕсли;
	Данные = Новый Структура;
	Данные.Вставить("name", Имя);
	Данные.Вставить("description", Описание);
	Данные.Вставить("arguments", Аргументы);
	Данные.Вставить("notify", Оповещение);
	Промпты = MCP_ПолучитьРеестр("MCP_Промпты");
	Промпты.Вставить(Имя, Данные);
КонецПроцедуры

// Обрабатывает JSON-RPC запрос MCP.
//
// Параметры:
//  Сообщение - Структура - Объект запроса JSON-RPC.
//  Сессия - Строка - Идентификатор сессии.
//
// Возвращаемое значение:
//  Структура - Ответ JSON-RPC или Неопределено.
Функция MCP_ОбработатьJSONRPC(Сообщение, Сессия) Экспорт
	Если ТипЗнч(Сообщение) <> Тип("Структура") И ТипЗнч(Сообщение) <> Тип("Соответствие") Тогда
		Возврат MCP_СформироватьОшибку(Неопределено, -32600, "Invalid Request");
	КонецЕсли;

	Идентификатор = MCP_ПолучитьСвойство(Сообщение, "id", Неопределено);
	Метод = MCP_ПолучитьСвойство(Сообщение, "method", "");
	Параметры = MCP_ПолучитьСвойство(Сообщение, "params", Новый Структура);

	Если Не ЗначениеЗаполнено(Метод) Тогда
		Если Идентификатор = Неопределено Тогда
			Возврат Неопределено;
		КонецЕсли;
		Возврат MCP_СформироватьОшибку(Идентификатор, -32600, "Invalid Request");
	КонецЕсли;

	Если Идентификатор = Неопределено Тогда
		// уведомление, ответа не требуется
		Возврат Неопределено;
	КонецЕсли;

	Если Метод = "initialize" Тогда
		Возврат MCP_ОтветИнициализация(Идентификатор, Параметры, Сессия);
	КонецЕсли;
	Если Метод = "ping" Тогда
		Возврат MCP_СформироватьОтвет(Идентификатор, Новый Структура);
	КонецЕсли;
	Если Метод = "tools/list" Тогда
		Возврат MCP_ОтветСписокИнструментов(Идентификатор);
	КонецЕсли;
	Если Метод = "tools/call" Тогда
		Возврат MCP_ОтветВызовИнструмента(Идентификатор, Параметры, Сессия);
	КонецЕсли;
	Если Метод = "resources/list" Тогда
		Возврат MCP_ОтветСписокРесурсов(Идентификатор);
	КонецЕсли;
	Если Метод = "resources/read" Тогда
		Возврат MCP_ОтветПрочитатьРесурс(Идентификатор, Параметры, Сессия);
	КонецЕсли;
	Если Метод = "prompts/list" Тогда
		Возврат MCP_ОтветСписокПромптов(Идентификатор);
	КонецЕсли;
	Если Метод = "prompts/get" Тогда
		Возврат MCP_ОтветПолучитьПромпт(Идентификатор, Параметры, Сессия);
	КонецЕсли;

	Возврат MCP_СформироватьОшибку(Идентификатор, -32601, "Method not found");
КонецФункции

// Формирует и отправляет уведомление логирования MCP.
//
// Параметры:
//  Уровень - Строка - Уровень логирования.
//  Текст - Строка - Текст сообщения.
//  Контекст - Структура - Дополнительный контекст (если есть).
Процедура MCP_ЛогСообщение(Уровень, Текст, Контекст = Неопределено) Экспорт
	Параметры = Новый Структура("level,message", Уровень, Текст);
	Если Контекст <> Неопределено Тогда
		Параметры.Вставить("context", Контекст);
	КонецЕсли;
	Уведомление = MCP_СформироватьУведомление("notifications/logMessage", Параметры);
	Мсп_СерверКлиент.ОтправитьУведомление(Уведомление);
КонецПроцедуры

// Читает JSON-строку и возвращает объект.
//
// Параметры:
//  ТекстJSON - Строка - JSON-строка.
//
// Возвращаемое значение:
//  Структура - Прочитанный объект.
Функция MCP_ПрочитатьJSONСтроку(ТекстJSON) Экспорт
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(ТекстJSON);
	Возврат ПрочитатьJSON(ЧтениеJSON, Истина);
КонецФункции

// Читает JSON-строку с подстановкой значения по умолчанию при ошибке.
//
// Параметры:
//  ТекстJSON - Строка - JSON-строка.
//  ЗначениеПоУмолчанию - Структура - Значение при ошибке чтения.
//
// Возвращаемое значение:
//  Структура - Прочитанный объект или значение по умолчанию.
Функция MCP_ПрочитатьJSONСтрокуБезОшибок(ТекстJSON, ЗначениеПоУмолчанию = Неопределено) Экспорт
	Попытка
		Возврат MCP_ПрочитатьJSONСтроку(ТекстJSON);
	Исключение
		Возврат ЗначениеПоУмолчанию;
	КонецПопытки;
КонецФункции

// Записывает объект в JSON-строку.
//
// Параметры:
//  Данные - Структура - Объект для сериализации.
//
// Возвращаемое значение:
//  Строка - JSON-представление данных.
Функция MCP_ЗаписатьJSON(Данные) Экспорт
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, Данные);
	Возврат ЗаписьJSON.Закрыть();
КонецФункции

// Получает свойство из структуры/соответствия с поддержкой значения по умолчанию.
//
// Параметры:
//  Данные - Структура - Структура или соответствие.
//  Имя - Строка - Имя свойства.
//  ЗначениеПоУмолчанию - Структура - Значение по умолчанию.
//
// Возвращаемое значение:
//  Структура - Значение свойства или значение по умолчанию.
Функция MCP_ПолучитьСвойство(Данные, Имя, ЗначениеПоУмолчанию) Экспорт
	Если ТипЗнч(Данные) = Тип("Структура") Тогда
		Значение = ЗначениеПоУмолчанию;
		Если Данные.Свойство(Имя, Значение) Тогда
			Возврат Значение;
		КонецЕсли;
	КонецЕсли;
	Если ТипЗнч(Данные) = Тип("Соответствие") Тогда
		Значение = Данные.Получить(Имя);
		Если Значение <> Неопределено Тогда
			Возврат Значение;
		КонецЕсли;
	КонецЕсли;
	Возврат ЗначениеПоУмолчанию;
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция MCP_ОтветИнициализация(Идентификатор, Параметры, Сессия)
	MCP_ИнициализироватьРеестры();
	Если ТипЗнч(Параметры) = Тип("Структура") Тогда
		Клиент = Новый Структура;
		ЗначениеКлиента = MCP_ПолучитьСвойство(Параметры, "clientInfo", Неопределено);
		Если ЗначениеКлиента <> Неопределено Тогда
			Клиент.Вставить("clientInfo", ЗначениеКлиента);
		КонецЕсли;
		ВерсияПротокола = MCP_ПолучитьСвойство(Параметры, "protocolVersion", "");
		Если ЗначениеЗаполнено(ВерсияПротокола) Тогда
			Клиент.Вставить("protocolVersion", ВерсияПротокола);
		КонецЕсли;
		Если ЗначениеЗаполнено(Сессия) Тогда
			Сессии = MCP_ПолучитьРеестр("MCP_Сессии");
			Сессии.Вставить(Сессия, Клиент);
		КонецЕсли;
	КонецЕсли;

	Результат = Новый Структура;
	Результат.Вставить("protocolVersion", "2025-11-25");
	Результат.Вставить("serverInfo", Новый Структура("name,version", "1C MCP Server", "0.1.0"));

	Возможности = Новый Структура;
	Возможности.Вставить("tools", Новый Структура("listChanged", Ложь));
	Возможности.Вставить("resources", Новый Структура("subscribe,listChanged", Ложь, Ложь));
	Возможности.Вставить("prompts", Новый Структура("listChanged", Ложь));
	Результат.Вставить("capabilities", Возможности);

	Возврат MCP_СформироватьОтвет(Идентификатор, Результат);
КонецФункции

Функция MCP_ОтветСписокИнструментов(Идентификатор)
	MCP_ИнициализироватьРеестры();
	Инструменты = Новый Массив;
	ИнструментыРеестр = MCP_ПолучитьРеестр("MCP_Инструменты");
	Для Каждого Элемент Из ИнструментыРеестр Цикл
		Дескриптор = Элемент.Значение;
		Инструменты.Добавить(Новый Структура(
			"name,description,inputSchema",
			Дескриптор.name,
			Дескриптор.description,
			Дескриптор.inputSchema
		));
	КонецЦикла;
	Возврат MCP_СформироватьОтвет(Идентификатор, Новый Структура("tools", Инструменты));
КонецФункции

Функция MCP_ОтветВызовИнструмента(Идентификатор, Параметры, Сессия)
	MCP_ИнициализироватьРеестры();
	ИмяИнструмента = MCP_ПолучитьСвойство(Параметры, "name", "");
	Аргументы = MCP_ПолучитьСвойство(Параметры, "arguments", Новый Структура);
	Если Не ЗначениеЗаполнено(ИмяИнструмента) Тогда
		Возврат MCP_СформироватьОшибку(Идентификатор, -32602, "Invalid params");
	КонецЕсли;

	ИнструментыРеестр = MCP_ПолучитьРеестр("MCP_Инструменты");
	Дескриптор = ИнструментыРеестр.Получить(ИмяИнструмента);
	Если Дескриптор = Неопределено Тогда
		Возврат MCP_СформироватьОшибку(Идентификатор, -32601, "Tool not found");
	КонецЕсли;

	Контекст = MCP_СформироватьКонтекст("tools", ИмяИнструмента, Аргументы, Сессия, Идентификатор, Параметры);
	Результат = MCP_ВыполнитьОповещение(Дескриптор.notify, Контекст, Идентификатор);
	Если Результат = Неопределено Тогда
		Возврат MCP_СформироватьОшибку(Идентификатор, -32603, "Tool execution error");
	КонецЕсли;

	Нормализовано = MCP_НормализоватьРезультатИнструмента(Результат);
	Если Нормализовано = Неопределено Тогда
		Возврат MCP_СформироватьОшибку(Идентификатор, -32603, "Tool result is invalid");
	КонецЕсли;

	Возврат MCP_СформироватьОтвет(Идентификатор, Нормализовано);
КонецФункции

Функция MCP_ОтветСписокРесурсов(Идентификатор)
	MCP_ИнициализироватьРеестры();
	Ресурсы = Новый Массив;
	РесурсыРеестр = MCP_ПолучитьРеестр("MCP_Ресурсы");
	Для Каждого Элемент Из РесурсыРеестр Цикл
		Дескриптор = Элемент.Значение;
		ДанныеРесурса = Новый Структура;
		ДанныеРесурса.Вставить("uri", Дескриптор.uri);
		ДанныеРесурса.Вставить("name", Дескриптор.name);
		ДанныеРесурса.Вставить("description", Дескриптор.description);
		ДанныеРесурса.Вставить("mimeType", Дескриптор.mimeType);
		Ресурсы.Добавить(ДанныеРесурса);
	КонецЦикла;
	Возврат MCP_СформироватьОтвет(Идентификатор, Новый Структура("resources", Ресурсы));
КонецФункции

Функция MCP_ОтветПрочитатьРесурс(Идентификатор, Параметры, Сессия)
	MCP_ИнициализироватьРеестры();
	URI = MCP_ПолучитьСвойство(Параметры, "uri", "");
	Если Не ЗначениеЗаполнено(URI) Тогда
		Возврат MCP_СформироватьОшибку(Идентификатор, -32602, "Invalid params");
	КонецЕсли;

	РесурсыРеестр = MCP_ПолучитьРеестр("MCP_Ресурсы");
	Дескриптор = РесурсыРеестр.Получить(URI);
	Если Дескриптор = Неопределено Тогда
		Возврат MCP_СформироватьОшибку(Идентификатор, -32601, "Resource not found");
	КонецЕсли;

	Контекст = MCP_СформироватьКонтекст("resources", URI, Новый Структура, Сессия, Идентификатор, Параметры);
	Результат = MCP_ВыполнитьОповещение(Дескриптор.notify, Контекст, Идентификатор);
	Если Результат = Неопределено Тогда
		Возврат MCP_СформироватьОшибку(Идентификатор, -32603, "Resource execution error");
	КонецЕсли;

	Нормализовано = MCP_НормализоватьРезультатРесурса(Результат, Дескриптор);
	Если Нормализовано = Неопределено Тогда
		Возврат MCP_СформироватьОшибку(Идентификатор, -32603, "Resource result is invalid");
	КонецЕсли;

	Возврат MCP_СформироватьОтвет(Идентификатор, Нормализовано);
КонецФункции

Функция MCP_ОтветСписокПромптов(Идентификатор)
	MCP_ИнициализироватьРеестры();
	Промпты = Новый Массив;
	ПромптыРеестр = MCP_ПолучитьРеестр("MCP_Промпты");
	Для Каждого Элемент Из ПромптыРеестр Цикл
		Дескриптор = Элемент.Значение;
		Промпты.Добавить(Новый Структура(
			"name,description,arguments",
			Дескриптор.name,
			Дескриптор.description,
			Дескриптор.arguments
		));
	КонецЦикла;
	Возврат MCP_СформироватьОтвет(Идентификатор, Новый Структура("prompts", Промпты));
КонецФункции

Функция MCP_ОтветПолучитьПромпт(Идентификатор, Параметры, Сессия)
	MCP_ИнициализироватьРеестры();
	ИмяПромпта = MCP_ПолучитьСвойство(Параметры, "name", "");
	Аргументы = MCP_ПолучитьСвойство(Параметры, "arguments", Новый Структура);
	Если Не ЗначениеЗаполнено(ИмяПромпта) Тогда
		Возврат MCP_СформироватьОшибку(Идентификатор, -32602, "Invalid params");
	КонецЕсли;

	ПромптыРеестр = MCP_ПолучитьРеестр("MCP_Промпты");
	Дескриптор = ПромптыРеестр.Получить(ИмяПромпта);
	Если Дескриптор = Неопределено Тогда
		Возврат MCP_СформироватьОшибку(Идентификатор, -32601, "Prompt not found");
	КонецЕсли;

	Контекст = MCP_СформироватьКонтекст("prompts", ИмяПромпта, Аргументы, Сессия, Идентификатор, Параметры);
	Результат = MCP_ВыполнитьОповещение(Дескриптор.notify, Контекст, Идентификатор);
	Если Результат = Неопределено Тогда
		Возврат MCP_СформироватьОшибку(Идентификатор, -32603, "Prompt execution error");
	КонецЕсли;

	Нормализовано = MCP_НормализоватьРезультатПромпта(Результат);
	Если Нормализовано = Неопределено Тогда
		Возврат MCP_СформироватьОшибку(Идентификатор, -32603, "Prompt result is invalid");
	КонецЕсли;

	Возврат MCP_СформироватьОтвет(Идентификатор, Нормализовано);
КонецФункции

Функция MCP_СформироватьОтвет(Идентификатор, Результат)
	Ответ = Новый Структура("jsonrpc,id", "2.0", Идентификатор);
	Ответ.Вставить("result", Результат);
	Возврат Ответ;
КонецФункции

Функция MCP_СформироватьОшибку(Идентификатор, Код, Сообщение)
	Ответ = Новый Структура("jsonrpc,id", "2.0", Идентификатор);
	Ошибка = Новый Структура("code,message", Код, Сообщение);
	Ответ.Вставить("error", Ошибка);
	Возврат Ответ;
КонецФункции

Функция MCP_СформироватьУведомление(Метод, Параметры)
	Данные = Новый Структура("jsonrpc,method", "2.0", Метод);
	Если Параметры <> Неопределено Тогда
		Данные.Вставить("params", Параметры);
	КонецЕсли;
	Возврат MCP_ЗаписатьJSON(Данные);
КонецФункции

Функция MCP_СформироватьКонтекст(Kind, ИмяИлиURI, Аргументы, Сессия, Идентификатор, Raw)
	Meta = Новый Структура;
	Сессии = MCP_ПолучитьРеестр("MCP_Сессии");
	Если Сессии <> Неопределено И ЗначениеЗаполнено(Сессия) Тогда
		СессионныеДанные = Сессии.Получить(Сессия);
		Если ТипЗнч(СессионныеДанные) = Тип("Структура") Тогда
			Для Каждого Пара Из СессионныеДанные Цикл
				Meta.Вставить(Пара.Ключ, Пара.Значение);
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;

	Контекст = Новый Структура;
	Контекст.Вставить("kind", Kind);
	Если Kind = "resources" Тогда
		Контекст.Вставить("uri", ИмяИлиURI);
	Иначе
		Контекст.Вставить("name", ИмяИлиURI);
	КонецЕсли;
	Контекст.Вставить("arguments", Аргументы);
	Контекст.Вставить("sessionId", Сессия);
	Контекст.Вставить("requestId", Идентификатор);
	Контекст.Вставить("raw", Raw);
	Контекст.Вставить("meta", Meta);
	Возврат Контекст;
КонецФункции

Функция MCP_ВыполнитьОповещение(Оповещение, Контекст, Идентификатор)
	Если Оповещение = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	Попытка
		Возврат Оповещение.Выполнить(Контекст);
	Исключение
		Возврат Неопределено;
	КонецПопытки;
КонецФункции

Функция MCP_НормализоватьРезультатИнструмента(Результат)
	Если ТипЗнч(Результат) = Тип("Структура") Тогда
		Если Результат.Свойство("content") Тогда
			Возврат Результат;
		КонецЕсли;
	КонецЕсли;
	Если ТипЗнч(Результат) = Тип("Массив") Тогда
		Возврат Новый Структура("content", Результат);
	КонецЕсли;
	Если ТипЗнч(Результат) = Тип("Строка") Тогда
		Контент = Новый Массив;
		Контент.Добавить(Новый Структура("type,text", "text", Результат));
		Возврат Новый Структура("content", Контент);
	КонецЕсли;
	Возврат Неопределено;
КонецФункции

Функция MCP_НормализоватьРезультатРесурса(Результат, Дескриптор)
	Если ТипЗнч(Результат) = Тип("Структура") Тогда
		Если Результат.Свойство("contents") Тогда
			Возврат Результат;
		КонецЕсли;
	КонецЕсли;
	Если ТипЗнч(Результат) = Тип("Массив") Тогда
		Возврат Новый Структура("contents", Результат);
	КонецЕсли;
	Если ТипЗнч(Результат) = Тип("Строка") Тогда
		Контент = Новый Структура("uri,text", Дескриптор.uri, Результат);
		Если ЗначениеЗаполнено(Дескриптор.mimeType) Тогда
			Контент.Вставить("mimeType", Дескриптор.mimeType);
		КонецЕсли;
		МассивКонтента = Новый Массив;
		МассивКонтента.Добавить(Контент);
		Возврат Новый Структура("contents", МассивКонтента);
	КонецЕсли;
	Возврат Неопределено;
КонецФункции

Функция MCP_НормализоватьРезультатПромпта(Результат)
	Если ТипЗнч(Результат) = Тип("Структура") Тогда
		Если Результат.Свойство("messages") Тогда
			Возврат Результат;
		КонецЕсли;
	КонецЕсли;
	Если ТипЗнч(Результат) = Тип("Массив") Тогда
		Возврат Новый Структура("messages", Результат);
	КонецЕсли;
	Если ТипЗнч(Результат) = Тип("Строка") Тогда
		Контент = Новый Массив;
		Контент.Добавить(Новый Структура("type,text", "text", Результат));
		Сообщение = Новый Структура("role,content", "user", Контент);
		Сообщения = Новый Массив;
		Сообщения.Добавить(Сообщение);
		Возврат Новый Структура("messages", Сообщения);
	КонецЕсли;
	Возврат Неопределено;
КонецФункции

Функция MCP_ПолучитьРеестр(Имя)
	Состояние = MCP_ПолучитьСостояние();
	Если Не Состояние.Свойство(Имя) Тогда
		Состояние.Вставить(Имя, Новый Соответствие);
	КонецЕсли;
	Возврат Состояние[Имя];
КонецФункции

Функция MCP_ПолучитьСостояние()
	Если Мсп_Состояние = Неопределено Тогда
		Мсп_Состояние = Новый Структура;
	КонецЕсли;
	Возврат Мсп_Состояние;
КонецФункции

#КонецОбласти
