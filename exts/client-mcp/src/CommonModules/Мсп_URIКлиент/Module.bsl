#Область ПрограммныйИнтерфейс

// Возвращает URI активного окна.
//
// Возвращаемое значение:
//  Строка - URI активного окна.
Функция URIАктивногоОкна() Экспорт
	Возврат "window://active";
КонецФункции

// Возвращает URI окна по навигационной ссылке.
//
// Параметры:
//  НавигационнаяСсылка - Строка - Навигационная ссылка окна.
//
// Возвращаемое значение:
//  Строка - URI окна.
Функция URIОкна(НавигационнаяСсылка) Экспорт
	Если Не ЗначениеЗаполнено(НавигационнаяСсылка) Тогда
		Возврат "";
	КонецЕсли;

	Возврат "window://" + КодСегментаURI(НавигационнаяСсылка);
КонецФункции

// Возвращает URI формы.
//
// Параметры:
//  ИмяФормы - Строка - Имя формы.
//
// Возвращаемое значение:
//  Строка - URI формы.
Функция URIФормы(ИмяФормы) Экспорт
	Если Не ЗначениеЗаполнено(ИмяФормы) Тогда
		Возврат "";
	КонецЕсли;

	Возврат "form://" + КодСегментаURI(ИмяФормы);
КонецФункции

// Возвращает URI элемента формы.
//
// Параметры:
//  ИмяФормы - Строка - Имя формы.
//  ИмяЭлемента - Строка - Имя элемента формы.
//
// Возвращаемое значение:
//  Строка - URI элемента формы.
Функция URIЭлементаФормы(ИмяФормы, ИмяЭлемента) Экспорт
	Если Не ЗначениеЗаполнено(ИмяФормы)
		ИЛИ Не ЗначениеЗаполнено(ИмяЭлемента) Тогда
		Возврат "";
	КонецЕсли;

	Возврат "control://"
		+ КодСегментаURI(ИмяФормы)
		+ "/"
		+ КодСегментаURI(ИмяЭлемента);
КонецФункции

// Проверяет, что URI указывает на окно.
//
// Параметры:
//  URI - Строка - Проверяемый URI.
//
// Возвращаемое значение:
//  Булево - Истина, если URI указывает на окно.
Функция ЭтоURIОкна(URI) Экспорт
	Возврат НачинаетсяС(URI, "window://");
КонецФункции

// Проверяет, что URI указывает на активное окно.
//
// Параметры:
//  URI - Строка - Проверяемый URI.
//
// Возвращаемое значение:
//  Булево - Истина, если URI указывает на активное окно.
Функция ЭтоURIАктивногоОкна(URI) Экспорт
	Возврат URI = URIАктивногоОкна();
КонецФункции

// Проверяет, что URI указывает на форму.
//
// Параметры:
//  URI - Строка - Проверяемый URI.
//
// Возвращаемое значение:
//  Булево - Истина, если URI указывает на форму.
Функция ЭтоURIФормы(URI) Экспорт
	Возврат НачинаетсяС(URI, "form://");
КонецФункции

// Проверяет, что URI указывает на элемент формы.
//
// Параметры:
//  URI - Строка - Проверяемый URI.
//
// Возвращаемое значение:
//  Булево - Истина, если URI указывает на элемент формы.
Функция ЭтоURIЭлементаФормы(URI) Экспорт
	Возврат НачинаетсяС(URI, "control://");
КонецФункции

// Возвращает сегмент окна из URI.
//
// Параметры:
//  URI - Строка - URI окна.
//
// Возвращаемое значение:
//  Строка - Сегмент окна.
Функция СегментОкна(URI) Экспорт
	Если Не ЭтоURIОкна(URI) Тогда
		Возврат "";
	КонецЕсли;

	Возврат Сред(URI, СтрДлина("window://") + 1);
КонецФункции

// Возвращает сегмент формы из URI.
//
// Параметры:
//  URI - Строка - URI формы.
//
// Возвращаемое значение:
//  Строка - Сегмент формы.
Функция СегментФормы(URI) Экспорт
	Если Не ЭтоURIФормы(URI) Тогда
		Возврат "";
	КонецЕсли;

	Возврат Сред(URI, СтрДлина("form://") + 1);
КонецФункции

// Возвращает сегменты URI элемента формы.
//
// Параметры:
//  URI - Строка - URI элемента формы.
//
// Возвращаемое значение:
//  Структура - Сегменты URI:
//   * СегментФормы - Строка - Сегмент формы.
//   * СегментЭлемента - Строка - Сегмент элемента формы.
//  Неопределено - URI элемента формы некорректен.
Функция СегментыЭлементаФормы(URI) Экспорт
	Если Не ЭтоURIЭлементаФормы(URI) Тогда
		Возврат Неопределено;
	КонецЕсли;

	Остаток = Сред(URI, СтрДлина("control://") + 1);
	ПозицияРазделителя = СтрНайти(Остаток, "/");
	Если ПозицияРазделителя = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;

	СегментФормы = Лев(Остаток, ПозицияРазделителя - 1);
	СегментЭлемента = Сред(Остаток, ПозицияРазделителя + 1);
	Если Не ЗначениеЗаполнено(СегментФормы)
		ИЛИ Не ЗначениеЗаполнено(СегментЭлемента) Тогда
		Возврат Неопределено;
	КонецЕсли;

	Возврат НовыеСегментыЭлементаФормы(СегментФормы, СегментЭлемента);
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция КодСегментаURI(Значение)
	Результат = "";
	Для НомерСимвола = 1 По СтрДлина(Значение) Цикл
		КодЮникода = КодСимвола(Значение, НомерСимвола);
		Если ЭтоБезопасныйБайтURI(КодЮникода) Тогда
			Результат = Результат + Сред(Значение, НомерСимвола, 1);
		Иначе
			Результат = Результат + КодЮникодаURI(КодЮникода);
		КонецЕсли;
	КонецЦикла;

	Возврат Результат;
КонецФункции

Функция ЭтоБезопасныйБайтURI(Байт)
	Возврат Байт >= 48 И Байт <= 57
		ИЛИ Байт >= 65 И Байт <= 90
		ИЛИ Байт >= 97 И Байт <= 122
		ИЛИ Байт = 45
		ИЛИ Байт = 46
		ИЛИ Байт = 95
		ИЛИ Байт = 126;
КонецФункции

Функция ШестнадцатеричныйБайт(Байт)
	ШестнадцатеричныеЦифры = "0123456789ABCDEF";
	СтаршаяЦифра = Цел(Байт / 16);
	МладшаяЦифра = Байт % 16;
	Возврат Сред(ШестнадцатеричныеЦифры, СтаршаяЦифра + 1, 1)
		+ Сред(ШестнадцатеричныеЦифры, МладшаяЦифра + 1, 1);
КонецФункции

Функция КодЮникодаURI(КодЮникода)
	Если КодЮникода <= 127 Тогда
		Возврат КодБайтаURI(КодЮникода);
	КонецЕсли;

	Если КодЮникода <= 2047 Тогда
		Возврат КодБайтаURI(192 + Цел(КодЮникода / 64))
			+ КодБайтаURI(128 + КодЮникода % 64);
	КонецЕсли;

	Если КодЮникода <= 65535 Тогда
		Возврат КодБайтаURI(224 + Цел(КодЮникода / 4096))
			+ КодБайтаURI(128 + Цел(КодЮникода / 64) % 64)
			+ КодБайтаURI(128 + КодЮникода % 64);
	КонецЕсли;

	Возврат КодБайтаURI(240 + Цел(КодЮникода / 262144))
		+ КодБайтаURI(128 + Цел(КодЮникода / 4096) % 64)
		+ КодБайтаURI(128 + Цел(КодЮникода / 64) % 64)
		+ КодБайтаURI(128 + КодЮникода % 64);
КонецФункции

Функция КодБайтаURI(Байт)
	Возврат "%" + ШестнадцатеричныйБайт(Байт);
КонецФункции

Функция НачинаетсяС(СтрокаЗначение, Префикс)
	Если СтрДлина(СтрокаЗначение) < СтрДлина(Префикс) Тогда
		Возврат Ложь;
	КонецЕсли;

	Возврат Лев(СтрокаЗначение, СтрДлина(Префикс)) = Префикс;
КонецФункции

Функция НовыеСегментыЭлементаФормы(СегментФормы, СегментЭлемента)
	Возврат Новый Структура("СегментФормы, СегментЭлемента", СегментФормы, СегментЭлемента);
КонецФункции

Функция Из16ВЧисло(Знач Значение)
	Результат = 0;
	Множитель = 1;
	Пока Значение <> "" Цикл
		Результат = Результат + Множитель * (Найти("0123456789ABCDEF", Прав(Значение, 1)) - 1);
		Множитель = Множитель * 16;
		Значение = Лев(Значение, СтрДлина(Значение) - 1);
	КонецЦикла;
	Возврат Результат;
КонецФункции

// Декодирует URL-кодированную строку.
//
// Параметры:
//  URL - Строка - URL-кодированная строка.
//
// Возвращаемое значение:
//  Строка - Декодированная строка.
Функция ДекодироватьURL(URL) Экспорт
	ДлинаСтроки = СтрДлина(URL);
	Инд = 1;
	Результат = "";
	ПолныйКод = 0;
	ОсталосьСимволов = 0;

	Пока Инд <= ДлинаСтроки Цикл
		Код = КодСимвола(URL, Инд);

		Если Код = 37 Тогда
			// Символ(37) = "%"
			Код = Из16ВЧисло(Сред(URL, Инд + 1, 2));
			Инд = Инд + 2;
		ИначеЕсли ОсталосьСимволов = 0 Тогда
			Результат = Результат + Символ(Код);
			Инд = Инд + 1;
			Продолжить;
		КонецЕсли;

		Если Код <= 127 Тогда
			// Код = 0b0ххххххх
			Результат = Результат + Символ(Код);
		ИначеЕсли Код <= 191 Тогда
			// Код = 0b10хххххх
			ПолныйКод = (ПолныйКод * 64) + (Код % 64);
			ОсталосьСимволов = ОсталосьСимволов - 1;
			Если ОсталосьСимволов = 0 Тогда
				Результат = Результат + Символ(ПолныйКод);
			КонецЕсли;
		ИначеЕсли Код <= 223 Тогда
			// Код = 0b110ххххх
			ПолныйКод = Код % 32;
			ОсталосьСимволов = 1;
		ИначеЕсли Код <= 239 Тогда
			// Код = 0b1110хххх
			ПолныйКод = Код % 16;
			ОсталосьСимволов = 2;
		ИначеЕсли Код <= 247 Тогда
			// Код = 0b11110ххх
			ПолныйКод = Код % 8;
			ОсталосьСимволов = 3;
		ИначеЕсли Код <= 251 Тогда
			// Код = 0b111110хх
			ПолныйКод = Код % 4;
			ОсталосьСимволов = 4;
		ИначеЕсли Код <= 253 Тогда
			// Код = 0b1111110х
			ПолныйКод = Код % 2;
			ОсталосьСимволов = 5;
		КонецЕсли;

		Инд = Инд + 1;
	КонецЦикла;

	Возврат Результат;
КонецФункции

#КонецОбласти
