#Область ПрограммныйИнтерфейс

// Запускает тест-клиент 1С и устанавливает соединение.
//
// Параметры:
//  Порт - Произвольный - Номер порта тест-клиента.
//
// Возвращаемое значение:
//  Структура - Результат выполнения.
Функция Запустить(Порт) Экспорт
	Порт = НормализоватьПорт(Порт);
	Мсп_ЛогированиеКлиент.Информация("Test client start requested port=%1", Порт);
	КомандаЗапуска = СформироватьКомандуЗапуска(Порт);
	Мсп_ЛогированиеКлиент.Ошибка("Test client command line: " + КомандаЗапуска);
	Если Не ЗначениеЗаполнено(КомандаЗапуска) Тогда
		Мсп_ЛогированиеКлиент.Ошибка("Test client start error: command line is empty");
		Возврат СформироватьРезультат(Ложь, Неопределено, "Не удалось сформировать команду запуска");
	КонецЕсли;

	РезультатЗапуска = ЗапуститьПроцессТестКлиента(КомандаЗапуска);
	Если Не РезультатЗапуска.Успех Тогда
		Мсп_ЛогированиеКлиент.Ошибка("Test client start error: %1", РезультатЗапуска.Ошибка);
		Возврат СформироватьРезультат(Ложь, Неопределено, РезультатЗапуска.Ошибка);
	КонецЕсли;

	ТестКлиент = СоздатьТестируемоеПриложение(Порт);
	РезультатПодключения = ПодключитьсяКТестКлиенту(ТестКлиент, 5);
	Если РезультатПодключения.Подключен Тогда
		Мсп_ЛогированиеКлиент.Информация("Test client connected port=%1", Порт);
	Иначе
		Мсп_ЛогированиеКлиент.Важно("Test client connect failed: %1", РезультатПодключения.Ошибка);
	КонецЕсли;

	Память = ПолучитьПамятьТестКлиент();
	Память.Вставить("КомандаЗапуска", КомандаЗапуска);
	Память.Вставить("ТестКлиент", ТестКлиент);
	Память.Вставить("Подключен", РезультатПодключения.Подключен);
	Память.Вставить("ПоследняяОшибка", РезультатПодключения.Ошибка);
	Память.Вставить("Порт", Порт);
	СохранитьПамятьТестКлиент(Память);

	Данные = Новый Структура("started,connected,port", Истина, РезультатПодключения.Подключен, Порт);
	Возврат СформироватьРезультат(РезультатПодключения.Подключен, Данные, РезультатПодключения.Ошибка);
КонецФункции

// Останавливает тест-клиент 1С и разрывает соединение.
//
// Возвращаемое значение:
//  Структура - Результат выполнения.
Функция Остановить() Экспорт
	Память = ПолучитьПамятьТестКлиент();
	ТестКлиент = ПолучитьЗначениеПамяти(Память, "ТестКлиент", Неопределено);
	Если ТестКлиент = Неопределено Тогда
		Мсп_ЛогированиеКлиент.Важно("Test client stop requested but no active client");
		Возврат СформироватьРезультат(Ложь, Новый Структура("stopped", Ложь), "test client not started");
	КонецЕсли;

	Мсп_ЛогированиеКлиент.Информация("Test client stop requested");
	Ошибка = "";
	Попытка
		ТестКлиент.РазорватьСоединение();
	Исключение
		Ошибка = ОписаниеОшибки();
	КонецПопытки;
	Если ЗначениеЗаполнено(Ошибка) Тогда
		Мсп_ЛогированиеКлиент.Ошибка("Test client stop error: %1", Ошибка);
	Иначе
		Мсп_ЛогированиеКлиент.Информация("Test client stopped");
	КонецЕсли;

	Память.Вставить("ТестКлиент", Неопределено);
	Память.Вставить("Подключен", Ложь);
	Память.Вставить("ПоследняяОшибка", Ошибка);
	СохранитьПамятьТестКлиент(Память);

	Данные = Новый Структура("stopped", Не ЗначениеЗаполнено(Ошибка));
	Возврат СформироватьРезультат(Не ЗначениеЗаполнено(Ошибка), Данные, Ошибка);
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция СформироватьРезультат(Успех, Данные, Ошибка)
	Результат = Новый Структура("ok", Успех);
	Если Данные <> Неопределено Тогда
		Результат.Вставить("data", Данные);
	КонецЕсли;
	Если ЗначениеЗаполнено(Ошибка) Тогда
		Результат.Вставить("error", Ошибка);
	КонецЕсли;
	Возврат Результат;
КонецФункции

Функция ПолучитьПамятьТестКлиент()
	Память = Мсп_СостояниеКлиент.ПолучитьСостояниеЗначение(КлючПамятиТестКлиент(), Неопределено);
	Если Память = Неопределено Тогда
		Память = Новый Структура;
		СохранитьПамятьТестКлиент(Память);
	КонецЕсли;
	Возврат Память;
КонецФункции

Процедура СохранитьПамятьТестКлиент(Память)
	Мсп_СостояниеКлиент.УстановитьСостояниеЗначение(КлючПамятиТестКлиент(), Память);
КонецПроцедуры

Функция КлючПамятиТестКлиент()
	Возврат "ПамятьТестКлиент";
КонецФункции

Функция ПолучитьЗначениеПамяти(Память, Имя, ЗначениеПоУмолчанию)
	Если Память = Неопределено Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;
	Значение = ЗначениеПоУмолчанию;
	Если Память.Свойство(Имя, Значение) Тогда
		Возврат Значение;
	КонецЕсли;
	Возврат ЗначениеПоУмолчанию;
КонецФункции

Функция ЗапуститьПроцессТестКлиента(КомандаЗапуска)
	Попытка
		ЗапуститьСистему(КомандаЗапуска);
		Возврат Новый Структура("Успех, Ошибка", Истина, "");
	Исключение
		Возврат Новый Структура("Успех, Ошибка", Ложь, ОписаниеОшибки());
	КонецПопытки;
КонецФункции

Функция СоздатьТестируемоеПриложение(Порт)
	Если Порт > 0 Тогда
		Возврат Новый ТестируемоеПриложение("127.0.0.1", Порт);
	КонецЕсли;
	Возврат Новый ТестируемоеПриложение();
КонецФункции

Функция ПодключитьсяКТестКлиенту(ТестКлиент, МаксИтераций)
	Подключен = Ложь;
	ПоследняяОшибка = "";
	Для Счетчик = 1 По МаксИтераций Цикл
		Попытка
			ТестКлиент.УстановитьСоединение();
			ПоследняяОшибка = Неопределено;
			Подключен = Истина;
			Прервать;
		Исключение
			ПоследняяОшибка = ОписаниеОшибки();
		КонецПопытки;
		Мсп_ПаузаВызовСервера.СделатьПаузу(1);
	КонецЦикла;
	Возврат Новый Структура("Подключен, Ошибка", Подключен, ПоследняяОшибка);
КонецФункции

Функция НормализоватьПорт(Порт)
	ЧислоПорта = 0;
	Если ТипЗнч(Порт) = Тип("Число") Тогда
		ЧислоПорта = Порт;
	ИначеЕсли ТипЗнч(Порт) = Тип("Строка") И ЗначениеЗаполнено(Порт) Тогда
		Попытка
			ЧислоПорта = Число(Порт);
		Исключение
			ЧислоПорта = 0;
		КонецПопытки;
	КонецЕсли;
	Если ЧислоПорта <= 0 Тогда
		ЧислоПорта = 1538;
	КонецЕсли;
	Возврат ЧислоПорта;
КонецФункции

Функция СформироватьКомандуЗапуска(Порт)
	КаталогПрограммыПути = КаталогПрограммы();
	Если Не ЗначениеЗаполнено(КаталогПрограммыПути) Тогда
		Возврат "";
	КонецЕсли;
	ПутьКПрограмме = ПодготовитьПутьКПрограмме(КаталогПрограммыПути);
	Если Не ЗначениеЗаполнено(ПутьКПрограмме) Тогда
		Возврат "";
	КонецЕсли;
	СтрокаПодключения = СтрокаСоединенияИнформационнойБазы();
	Если Не ЗначениеЗаполнено(СтрокаПодключения) Тогда
		Возврат "";
	КонецЕсли;
	КомандаЗапуска = ПутьКПрограмме + " ENTERPRISE " + СтрокаПодключения + " /TESTCLIENT";
	КомандаЗапуска = КомандаЗапуска + " -TPort" + Формат(Порт, "ЧГ=0;");
	Возврат КомандаЗапуска;
КонецФункции

Функция ПодготовитьПутьКПрограмме(КаталогПрограммыПути)
	Если Не ЗначениеЗаполнено(КаталогПрограммыПути) Тогда
		Возврат "";
	КонецЕсли;
	
	ПутьКПрограмме = КаталогПрограммыПути + "1cv8с";
	Если СтрНайти(ПутьКПрограмме, " ") > 0 Тогда
		ПутьКПрограмме = """" + ПутьКПрограмме + """";
	КонецЕсли;
	Возврат ПутьКПрограмме;
КонецФункции

#КонецОбласти
