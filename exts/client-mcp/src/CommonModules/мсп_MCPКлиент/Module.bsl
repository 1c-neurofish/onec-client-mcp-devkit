#Область ПрограммныйИнтерфейс

// Запускает MCP-сервер на указанном порту.
Асинх Функция ЗапуститьСервер(Порт, Параметры = Неопределено) Экспорт
	Возврат Ждать мсп_СерверКлиент.ЗапуститьСервер(Порт, Параметры);
КонецФункции

// Останавливает MCP-сервер.
Процедура ОстановитьСервер() Экспорт
	мсп_СерверКлиент.ОстановитьСервер();
КонецПроцедуры

// Регистрирует инструмент MCP и обработчик его вызова.
Процедура ЗарегистрироватьИнструмент(Имя, Описание, СхемаJSON, Оповещение) Экспорт
	мсп_ИнструментыКлиент.MCP_ЗарегистрироватьИнструмент(Имя, Описание, СхемаJSON, Оповещение);
КонецПроцедуры

// Регистрирует ресурс MCP и обработчик чтения.
Процедура ЗарегистрироватьРесурс(URI, Описание, MimeType, Оповещение) Экспорт
	мсп_ИнструментыКлиент.MCP_ЗарегистрироватьРесурс(URI, Описание, MimeType, Оповещение);
КонецПроцедуры

// Регистрирует промпт MCP и обработчик получения.
Процедура ЗарегистрироватьПромпт(Имя, Описание, Аргументы, Оповещение) Экспорт
	мсп_ИнструментыКлиент.MCP_ЗарегистрироватьПромпт(Имя, Описание, Аргументы, Оповещение);
КонецПроцедуры

// Отправляет лог-сообщение в MCP.
Процедура ЛогСообщение(Уровень, Текст, Контекст = Неопределено) Экспорт
	мсп_ИнструментыКлиент.MCP_ЛогСообщение(Уровень, Текст, Контекст);
КонецПроцедуры

#КонецОбласти
