#Область ПрограммныйИнтерфейс

// Регистрирует сценарии тестового модуля.
Процедура ИсполняемыеСценарии() Экспорт
	ЮТТесты
		.ДобавитьТест("РезультатРесурсаВозвращаетСтруктуруСContents")
		.ДобавитьТест("РезультатРесурсаСодержитURI")
		.ДобавитьТест("РезультатРесурсаСодержитJSON")
		.ДобавитьТест("РезультатРесурсаСодержитMimeType")
		.ДобавитьТест("НовыйОписаниеРесурсаЗаполняетПоля")
		.ДобавитьТест("НовыйОписаниеРесурсаУстанавливаетMimeTypeJSON")
		.ДобавитьТест("НовыйОписаниеШаблонаРесурсаЗаполняетПоля")
		.ДобавитьТест("НовыйОписаниеШаблонаРесурсаУстанавливаетMimeTypeJSON")
		.ДобавитьТест("РезультатРесурсаИзРазрешенияВозвращаетОшибкуПриКодеОшибки")
		.ДобавитьТест("РезультатРесурсаИзРазрешенияВозвращаетОшибкуПриОтсутствииОбъекта")
		.ДобавитьТест("РезультатРесурсаИзРазрешенияВозвращаетОшибкуПриОтсутствииСнимка")
		.ДобавитьТест("РезультатРесурсаИзРазрешенияВозвращаетРезультат");
КонецПроцедуры

// Проверяет, что РезультатРесурса возвращает структуру с полем contents.
Процедура РезультатРесурсаВозвращаетСтруктуруСContents() Экспорт
	Результат = Мсп_РесурсыКлиент.РезультатРесурса("test://ресурс", Новый Структура("ключ", "значение"));

	ЮТест.ОжидаетЧто(Результат.Свойство("contents")).ЭтоИстина();
КонецПроцедуры

// Проверяет, что РезультатРесурса содержит URI в контенте.
Процедура РезультатРесурсаСодержитURI() Экспорт
	Результат = Мсп_РесурсыКлиент.РезультатРесурса("test://ресурс", Новый Структура);

	ЮТест.ОжидаетЧто(Результат.contents.Количество()).ИмеетДлинуБольше(0);
	ЮТест.ОжидаетЧто(Результат.contents[0].uri).Равно("test://ресурс");
КонецПроцедуры

// Проверяет, что РезультатРесурса содержит JSON в поле text с нужными значениями.
Процедура РезультатРесурсаСодержитJSON() Экспорт
	Данные = Новый Структура("имя", "тест");

	Результат = Мсп_РесурсыКлиент.РезультатРесурса("test://ресурс", Данные);

	ЮТест.ОжидаетЧто(ТипЗнч(Результат.contents[0].text)).Равно(Тип("Строка"));
	ЮТест.ОжидаетЧто(Результат.contents[0].text).Содержит("имя");
	ЮТест.ОжидаетЧто(Результат.contents[0].text).Содержит("тест");
КонецПроцедуры

// Проверяет, что РезультатРесурса содержит mimeType = application/json.
Процедура РезультатРесурсаСодержитMimeType() Экспорт
	Результат = Мсп_РесурсыКлиент.РезультатРесурса("test://ресурс", Новый Структура);

	ЮТест.ОжидаетЧто(Результат.contents[0].mimeType).Равно("application/json");
КонецПроцедуры

// Проверяет, что НовыйОписаниеРесурса заполняет все поля включая Обработчик.
Процедура НовыйОписаниеРесурсаЗаполняетПоля() Экспорт
	Оповещение = Новый ОписаниеОповещения("ОбработчикТест", ЭтотОбъект);

	Описание = Мсп_РесурсыКлиент.НовыйОписаниеРесурса("test://ресурс", "Ресурс", "Описание", Оповещение);

	ЮТест.ОжидаетЧто(Описание)
		.Свойство("URI").Равно("test://ресурс")
		.Свойство("Имя").Равно("Ресурс")
		.Свойство("Описание").Равно("Описание");
	ЮТест.ОжидаетЧто(Описание.Обработчик).Равно(Оповещение);
КонецПроцедуры

// Проверяет, что НовыйОписаниеРесурса устанавливает MimeType = application/json.
Процедура НовыйОписаниеРесурсаУстанавливаетMimeTypeJSON() Экспорт
	Описание = Мсп_РесурсыКлиент.НовыйОписаниеРесурса("test://ресурс", "", "", Новый ОписаниеОповещения());

	ЮТест.ОжидаетЧто(Описание.MimeType).Равно("application/json");
КонецПроцедуры

// Проверяет, что НовыйОписаниеШаблонаРесурса заполняет все поля.
Процедура НовыйОписаниеШаблонаРесурсаЗаполняетПоля() Экспорт
	Оповещение = Новый ОписаниеОповещения("ОбработчикТест", ЭтотОбъект);

	Описание = Мсп_РесурсыКлиент.НовыйОписаниеШаблонаРесурса("test://ресурс/{id}", "Шаблон", "Описание", Оповещение);

	ЮТест.ОжидаетЧто(Описание)
		.Свойство("URIШаблон").Равно("test://ресурс/{id}")
		.Свойство("Имя").Равно("Шаблон")
		.Свойство("Описание").Равно("Описание");
КонецПроцедуры

// Проверяет, что НовыйОписаниеШаблонаРесурса устанавливает MimeType = application/json.
Процедура НовыйОписаниеШаблонаРесурсаУстанавливаетMimeTypeJSON() Экспорт
	Описание = Мсп_РесурсыКлиент.НовыйОписаниеШаблонаРесурса("test://ресурс/{id}", "", "", Новый ОписаниеОповещения());

	ЮТест.ОжидаетЧто(Описание.MimeType).Равно("application/json");
КонецПроцедуры

// Проверяет, что РезультатРесурсаИзРазрешения возвращает ошибку при заполненном КодОшибки.
Процедура РезультатРесурсаИзРазрешенияВозвращаетОшибкуПриКодеОшибки() Экспорт
	РезультатРазрешения = Новый Структура("КодОшибки,Ошибка", "ACTION_FAILED", "что-то пошло не так");

	Результат = Мсп_РесурсыКлиент.РезультатРесурсаИзРазрешения(
		"test://ресурс", РезультатРазрешения, "Объект", "Сущность", Новый ОписаниеОповещения());

	ЮТест.ОжидаетЧто(Результат.Свойство("КодОшибки")).ЭтоИстина();
	ЮТест.ОжидаетЧто(Результат.КодОшибки).Равно("ACTION_FAILED");
КонецПроцедуры

// Проверяет, что РезультатРесурсаИзРазрешения возвращает ошибку если объект не найден.
Процедура РезультатРесурсаИзРазрешенияВозвращаетОшибкуПриОтсутствииОбъекта() Экспорт
	РезультатРазрешения = Новый Структура("КодОшибки", "");

	Результат = Мсп_РесурсыКлиент.РезультатРесурсаИзРазрешения(
		"test://ресурс", РезультатРазрешения, "НесуществующееПоле", "Сущность", Новый ОписаниеОповещения());

	ЮТест.ОжидаетЧто(Результат.Свойство("КодОшибки")).ЭтоИстина();
	ЮТест.ОжидаетЧто(Результат.КодОшибки).Равно("ACTION_FAILED");
КонецПроцедуры

// Проверяет, что РезультатРесурсаИзРазрешения возвращает ошибку если снимок не определен.
Процедура РезультатРесурсаИзРазрешенияВозвращаетОшибкуПриОтсутствииСнимка() Экспорт
	РезультатРазрешения = Новый Структура("КодОшибки,Объект", "", Новый Структура);
	ОбработчикСнимка = Новый ОписаниеОповещения("ОбработчикВозвращаетНеопределено", ЭтотОбъект);

	Результат = Мсп_РесурсыКлиент.РезультатРесурсаИзРазрешения(
		"test://ресурс", РезультатРазрешения, "Объект", "Сущность", ОбработчикСнимка);

	ЮТест.ОжидаетЧто(Результат.Свойство("КодОшибки")).ЭтоИстина();
	ЮТест.ОжидаетЧто(Результат.КодОшибки).Равно("ACTION_FAILED");
КонецПроцедуры

// Проверяет, что РезультатРесурсаИзРазрешения возвращает результат при успешном разрешении.
Процедура РезультатРесурсаИзРазрешенияВозвращаетРезультат() Экспорт
	РезультатРазрешения = Новый Структура("КодОшибки,Объект", "", Новый Структура("имя", "тест"));
	ОбработчикСнимка = Новый ОписаниеОповещения("ОбработчикВозвращаетСнимок", ЭтотОбъект);

	Результат = Мсп_РесурсыКлиент.РезультатРесурсаИзРазрешения(
		"test://ресурс", РезультатРазрешения, "Объект", "Сущность", ОбработчикСнимка);

	ЮТест.ОжидаетЧто(Результат.Свойство("contents")).ЭтоИстина();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ОбработчикВозвращаетНеопределено(Объект) Экспорт
	Возврат Неопределено;
КонецФункции

Функция ОбработчикВозвращаетСнимок(Объект) Экспорт
	Возврат Новый Структура("снимок", "данные");
КонецФункции

#КонецОбласти
