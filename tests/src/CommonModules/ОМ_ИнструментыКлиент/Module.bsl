#Область ПрограммныйИнтерфейс

// Регистрирует сценарии тестового модуля.
Процедура ИсполняемыеСценарии() Экспорт
	ЮТТесты
		.ДобавитьТест("НовыйОписаниеИнструментаЗаполняетПоля")
		.ДобавитьТест("НовыйОписаниеИнструментаУстанавливаетСхемуПараметров")
		.ДобавитьТест("НовыйОписаниеИнструментаУстанавливаетОбработчик");
КонецПроцедуры

// Проверяет, что НовыйОписаниеИнструмента заполняет поля Имя и Описание.
Процедура НовыйОписаниеИнструментаЗаполняетПоля() Экспорт
	Оповещение = Новый ОписаниеОповещения("ОбработчикТест", ЭтотОбъект);

	Описание = Мсп_ИнструментыКлиент.НовыйОписаниеИнструмента("мой_инструмент", "Описание инструмента", Новый Структура, Оповещение);

	ЮТест.ОжидаетЧто(Описание)
		.Свойство("Имя").Равно("мой_инструмент")
		.Свойство("Описание").Равно("Описание инструмента");
КонецПроцедуры

// Проверяет, что НовыйОписаниеИнструмента устанавливает СхемаПараметров из переданного значения.
Процедура НовыйОписаниеИнструментаУстанавливаетСхемуПараметров() Экспорт
	Схема = Новый Структура("type", "object");

	Описание = Мсп_ИнструментыКлиент.НовыйОписаниеИнструмента("инструмент", "", Схема, Новый ОписаниеОповещения());

	ЮТест.ОжидаетЧто(Описание.СхемаПараметров).Равно(Схема);
КонецПроцедуры

// Проверяет, что НовыйОписаниеИнструмента устанавливает Обработчик из переданного оповещения.
Процедура НовыйОписаниеИнструментаУстанавливаетОбработчик() Экспорт
	Оповещение = Новый ОписаниеОповещения("ОбработчикТест", ЭтотОбъект);

	Описание = Мсп_ИнструментыКлиент.НовыйОписаниеИнструмента("инструмент", "", Неопределено, Оповещение);

	ЮТест.ОжидаетЧто(Описание.Обработчик).Равно(Оповещение);
КонецПроцедуры

#КонецОбласти
