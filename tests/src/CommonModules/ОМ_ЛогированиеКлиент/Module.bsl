#Область ПрограммныйИнтерфейс

// Регистрирует сценарии тестового модуля.
Процедура ИсполняемыеСценарии() Экспорт
	ЮТТесты
		.ДобавитьТест("УстановитьПараметрыЛогированияСохраняетЗначения")
		.ДобавитьТест("УстановитьПараметрыЛогированияБезУровняНеМеняетУровень")
		.ДобавитьТест("ЛогированиеВключеноПослеУстановки")
		.ДобавитьТест("ЛогированиеВыключеноПослеУстановки")
		.ДобавитьТест("ПолучитьФайлЛогаВозвращаетУстановленноеЗначение")
		.ДобавитьТест("ПолучитьУровеньЛогаВозвращаетУстановленноеЗначение")
		.ДобавитьТест("ПрименитьПараметрыЗапускаПрименяетLog")
		.ДобавитьТест("ПрименитьПараметрыЗапускаПрименяетLogLevel")
		.ДобавитьТест("ПрименитьПараметрыЗапускаПрименяетLogFile")
		.ДобавитьТест("ПрименитьПараметрыЗапускаИгнорируетНеСтруктуру")
		.ДобавитьТест("ПрименитьПараметрыЗапускаИгнорируетНеопределено")
		.ДобавитьТест("ПрименитьПараметрыЗапускаЧастичныеПараметры");
КонецПроцедуры

// Проверяет, что УстановитьПараметрыЛогирования сохраняет все три поля.
Процедура УстановитьПараметрыЛогированияСохраняетЗначения() Экспорт
	ПодготовитьСостояние();

	Мсп_ЛогированиеКлиент.УстановитьПараметрыЛогирования(Истина, "/tmp/test.log", "warn");

	ЮТест.ОжидаетЧто(Мсп_ЛогированиеКлиент.ЛогированиеВключено()).ЭтоИстина();
	ЮТест.ОжидаетЧто(Мсп_ЛогированиеКлиент.ПолучитьФайлЛога()).Равно("/tmp/test.log");
	ЮТест.ОжидаетЧто(Мсп_ЛогированиеКлиент.ПолучитьУровеньЛога()).Равно("warn");
КонецПроцедуры

// Проверяет, что УстановитьПараметрыЛогирования без уровня не меняет текущий уровень.
Процедура УстановитьПараметрыЛогированияБезУровняНеМеняетУровень() Экспорт
	ПодготовитьСостояние();
	Мсп_ЛогированиеКлиент.УстановитьПараметрыЛогирования(Истина, "", "error");

	Мсп_ЛогированиеКлиент.УстановитьПараметрыЛогирования(Ложь, "");

	ЮТест.ОжидаетЧто(Мсп_ЛогированиеКлиент.ПолучитьУровеньЛога()).Равно("error");
КонецПроцедуры

// Проверяет ЛогированиеВключено после включения.
Процедура ЛогированиеВключеноПослеУстановки() Экспорт
	ПодготовитьСостояние();
	Мсп_ЛогированиеКлиент.УстановитьПараметрыЛогирования(Истина, "");

	ЮТест.ОжидаетЧто(Мсп_ЛогированиеКлиент.ЛогированиеВключено()).ЭтоИстина();
КонецПроцедуры

// Проверяет ЛогированиеВключено после выключения.
Процедура ЛогированиеВыключеноПослеУстановки() Экспорт
	ПодготовитьСостояние();
	Мсп_ЛогированиеКлиент.УстановитьПараметрыЛогирования(Ложь, "");

	ЮТест.ОжидаетЧто(Мсп_ЛогированиеКлиент.ЛогированиеВключено()).ЭтоЛожь();
КонецПроцедуры

// Проверяет ПолучитьФайлЛога после установки.
Процедура ПолучитьФайлЛогаВозвращаетУстановленноеЗначение() Экспорт
	ПодготовитьСостояние();
	Мсп_ЛогированиеКлиент.УстановитьПараметрыЛогирования(Ложь, "/var/log/mcp.log");

	ЮТест.ОжидаетЧто(Мсп_ЛогированиеКлиент.ПолучитьФайлЛога()).Равно("/var/log/mcp.log");
КонецПроцедуры

// Проверяет ПолучитьУровеньЛога после установки.
Процедура ПолучитьУровеньЛогаВозвращаетУстановленноеЗначение() Экспорт
	ПодготовитьСостояние();
	Мсп_ЛогированиеКлиент.УстановитьПараметрыЛогирования(Ложь, "", "debug");

	ЮТест.ОжидаетЧто(Мсп_ЛогированиеКлиент.ПолучитьУровеньЛога()).Равно("debug");
КонецПроцедуры

// Проверяет, что ПрименитьПараметрыЗапуска применяет поле log.
Процедура ПрименитьПараметрыЗапускаПрименяетLog() Экспорт
	ПодготовитьСостояние();
	Мсп_ЛогированиеКлиент.УстановитьПараметрыЛогирования(Ложь, "");

	Мсп_ЛогированиеКлиент.ПрименитьПараметрыЗапуска(Новый Структура("log", Истина));

	ЮТест.ОжидаетЧто(Мсп_ЛогированиеКлиент.ЛогированиеВключено()).ЭтоИстина();
КонецПроцедуры

// Проверяет, что ПрименитьПараметрыЗапуска применяет поле logLevel.
Процедура ПрименитьПараметрыЗапускаПрименяетLogLevel() Экспорт
	ПодготовитьСостояние();
	Мсп_ЛогированиеКлиент.УстановитьПараметрыЛогирования(Ложь, "", "info");

	Мсп_ЛогированиеКлиент.ПрименитьПараметрыЗапуска(Новый Структура("logLevel", "error"));

	ЮТест.ОжидаетЧто(Мсп_ЛогированиеКлиент.ПолучитьУровеньЛога()).Равно("error");
КонецПроцедуры

// Проверяет, что ПрименитьПараметрыЗапуска применяет поле logFile.
Процедура ПрименитьПараметрыЗапускаПрименяетLogFile() Экспорт
	ПодготовитьСостояние();
	Мсп_ЛогированиеКлиент.УстановитьПараметрыЛогирования(Ложь, "");

	Мсп_ЛогированиеКлиент.ПрименитьПараметрыЗапуска(Новый Структура("logFile", "/tmp/mcp.log"));

	ЮТест.ОжидаетЧто(Мсп_ЛогированиеКлиент.ПолучитьФайлЛога()).Равно("/tmp/mcp.log");
КонецПроцедуры

// Проверяет, что ПрименитьПараметрыЗапуска игнорирует не-Структуру.
Процедура ПрименитьПараметрыЗапускаИгнорируетНеСтруктуру() Экспорт
	ПодготовитьСостояние();
	Мсп_ЛогированиеКлиент.УстановитьПараметрыЛогирования(Ложь, "", "warn");

	Мсп_ЛогированиеКлиент.ПрименитьПараметрыЗапуска("строка");

	ЮТест.ОжидаетЧто(Мсп_ЛогированиеКлиент.ПолучитьУровеньЛога()).Равно("warn");
КонецПроцедуры

// Проверяет, что ПрименитьПараметрыЗапуска игнорирует Неопределено.
Процедура ПрименитьПараметрыЗапускаИгнорируетНеопределено() Экспорт
	ПодготовитьСостояние();
	Мсп_ЛогированиеКлиент.УстановитьПараметрыЛогирования(Истина, "", "error");

	Мсп_ЛогированиеКлиент.ПрименитьПараметрыЗапуска(Неопределено);

	ЮТест.ОжидаетЧто(Мсп_ЛогированиеКлиент.ЛогированиеВключено()).ЭтоИстина();
	ЮТест.ОжидаетЧто(Мсп_ЛогированиеКлиент.ПолучитьУровеньЛога()).Равно("error");
КонецПроцедуры

// Проверяет, что ПрименитьПараметрыЗапуска с частичными параметрами меняет только указанные поля.
Процедура ПрименитьПараметрыЗапускаЧастичныеПараметры() Экспорт
	ПодготовитьСостояние();
	Мсп_ЛогированиеКлиент.УстановитьПараметрыЛогирования(Ложь, "/old.log", "info");

	// Только logLevel — остальные не должны измениться
	Мсп_ЛогированиеКлиент.ПрименитьПараметрыЗапуска(Новый Структура("logLevel", "debug"));

	ЮТест.ОжидаетЧто(Мсп_ЛогированиеКлиент.ЛогированиеВключено()).ЭтоЛожь();
	ЮТест.ОжидаетЧто(Мсп_ЛогированиеКлиент.ПолучитьФайлЛога()).Равно("/old.log");
	ЮТест.ОжидаетЧто(Мсп_ЛогированиеКлиент.ПолучитьУровеньЛога()).Равно("debug");
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ПодготовитьСостояние()
	Мсп_СостояниеКлиент.УстановитьСостояниеЗначение(
		"ПараметрыЛогирования",
		Новый Структура("Логировать,УровеньЛога,ФайлЛога", Ложь, "error", ""));
КонецПроцедуры

#КонецОбласти
