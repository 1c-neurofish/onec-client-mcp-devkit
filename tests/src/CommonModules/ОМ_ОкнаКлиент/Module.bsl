#Область ПрограммныйИнтерфейс

// Регистрирует сценарии тестового модуля.
Процедура ИсполняемыеСценарии() Экспорт
	ЮТТесты.ДобавитьТест("ПолучитьАктивноеОкноБезКлиента")
		.ДобавитьТест("ПолучитьАктивноеОкноСНекорректнымКлиентом")
		.ДобавитьТест("ПолучитьСписокОконБезКлиента")
		.ДобавитьТест("ПолучитьСписокОконСНекорректнымКлиентом")
		.ДобавитьТест("СформироватьСнимокОкна");
КонецПроцедуры

// Проверяет ошибку при отсутствии клиента.
Процедура ПолучитьАктивноеОкноБезКлиента() Экспорт
	ПодготовитьСостояниеТестКлиента();

	Результат = Мсп_ОкнаКлиент.ПолучитьАктивноеОкно();

	ЮТест.ОжидаетЧто(Результат)
		.Свойство("Окно").НеЗаполнено()
		.Свойство("Ошибка").Равно("test client not connected");
КонецПроцедуры

// Проверяет обработку ошибки при некорректном объекте клиента.
Процедура ПолучитьАктивноеОкноСНекорректнымКлиентом() Экспорт
	ПодготовитьСостояниеТестКлиента(Новый Структура("Имя", "НекорректныйКлиент"));

	Результат = Мсп_ОкнаКлиент.ПолучитьАктивноеОкно();

	ЮТест.ОжидаетЧто(Результат)
		.Свойство("Окно").НеЗаполнено()
		.Свойство("Ошибка").Заполнено();
КонецПроцедуры

// Проверяет ошибку при отсутствии клиента при чтении списка окон.
Процедура ПолучитьСписокОконБезКлиента() Экспорт
	ПодготовитьСостояниеТестКлиента();

	Результат = Мсп_ОкнаКлиент.ПолучитьСписокОкон();

	ЮТест.ОжидаетЧто(Результат)
		.Свойство("Ошибка").Равно("test client not connected")
		.Свойство("Окна").ИмеетДлину(0);
КонецПроцедуры

// Проверяет обработку ошибки при некорректном объекте клиента при чтении списка окон.
Процедура ПолучитьСписокОконСНекорректнымКлиентом() Экспорт
	ПодготовитьСостояниеТестКлиента(Новый Структура("Имя", "НекорректныйКлиент"));

	Результат = Мсп_ОкнаКлиент.ПолучитьСписокОкон();

	ЮТест.ОжидаетЧто(Результат)
		.Свойство("Ошибка").Заполнено()
		.Свойство("Окна").ИмеетДлину(0);
КонецПроцедуры

// Проверяет контракт снимка окна.
Процедура СформироватьСнимокОкна() Экспорт
	Окно = Новый Структура("Заголовок,Основное,НачальнаяСтраница", "Главное окно", Истина, Ложь);

	Снимок = Мсп_ОкнаКлиент.СформироватьСнимокОкна(Окно);

	ЮТест.ОжидаетЧто(Снимок)
		.Свойство("type").Равно("window")
		.Свойство("title").Равно("Главное окно")
		.Свойство("isMain").Равно(Истина)
		.Свойство("homePage").Равно(Ложь)
		.Свойство("children").ИмеетДлину(0);
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ПодготовитьСостояниеТестКлиента(ТестКлиент = Неопределено)
	Мсп_СостояниеКлиент.УстановитьСостояниеЗначение(
		"ПараметрыЛогирования",
		Новый Структура("Логировать,УровеньЛога,ФайлЛога", Ложь, "error", ""));
	Память = Новый Структура;
	Если ТестКлиент <> Неопределено Тогда
		Память.Вставить("ТестКлиент", ТестКлиент);
	КонецЕсли;
	Мсп_СостояниеКлиент.УстановитьСостояниеЗначение("ПамятьТестКлиент", Память);
КонецПроцедуры

#КонецОбласти
