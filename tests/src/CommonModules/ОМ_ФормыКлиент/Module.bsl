#Область ПрограммныйИнтерфейс

// Регистрирует сценарии тестового модуля.
Процедура ИсполняемыеСценарии() Экспорт
	ЮТТесты.ДобавитьТест("СформироватьБазовыйСнимокФормыБезЗаголовка")
		.ДобавитьТест("СформироватьБазовыйСнимокФормыСЗаголовком")
		.ДобавитьТест("URIФормыКодируетИмяФормы")
		.ДобавитьТест("URIЭлементаФормыКодируетИмяФормыИЭлемента");
КонецПроцедуры

// Проверяет базовый снимок формы без заголовка.
Процедура СформироватьБазовыйСнимокФормыБезЗаголовка() Экспорт
	Снимок = Мсп_ФормыКлиент.СформироватьБазовыйСнимокФормы();

	ЮТест.ОжидаетЧто(Снимок)
		.Свойство("type").Равно("form")
		.Свойство("children").ИмеетДлину(0);
	ЮТест.ОжидаетЧто(Снимок.Свойство("title")).Равно(Ложь, "Заголовок не должен добавляться");
КонецПроцедуры

// Проверяет базовый снимок формы с заголовком.
Процедура СформироватьБазовыйСнимокФормыСЗаголовком() Экспорт
	Снимок = Мсп_ФормыКлиент.СформироватьБазовыйСнимокФормы("Справочник");

	ЮТест.ОжидаетЧто(Снимок)
		.Свойство("type").Равно("form")
		.Свойство("title").Равно("Справочник")
		.Свойство("children").ИмеетДлину(0);
КонецПроцедуры

// Проверяет формирование URI формы.
Процедура URIФормыКодируетИмяФормы() Экспорт
	Форма = Новый Структура("ИмяФормы", "Справочник.Номенклатура.Форма?1");

	URI = Мсп_ФормыКлиент.URIФормы(Форма);

	ЮТест.ОжидаетЧто(URI).Равно("form://%D0%A1%D0%BF%D1%80%D0%B0%D0%B2%D0%BE%D1%87%D0%BD%D0%B8%D0%BA.%D0%9D%D0%BE%D0%BC%D0%B5%D0%BD%D0%BA%D0%BB%D0%B0%D1%82%D1%83%D1%80%D0%B0.%D0%A4%D0%BE%D1%80%D0%BC%D0%B0%3F1");
КонецПроцедуры

// Проверяет формирование URI элемента формы.
Процедура URIЭлементаФормыКодируетИмяФормыИЭлемента() Экспорт
	Форма = Новый Структура("ИмяФормы", "Документ.Заказ");
	Элемент = Новый Структура("Имя", "Поле/Сумма");

	URI = Мсп_ФормыКлиент.URIЭлементаФормы(Форма, Элемент);

	ЮТест.ОжидаетЧто(URI).Равно("control://%D0%94%D0%BE%D0%BA%D1%83%D0%BC%D0%B5%D0%BD%D1%82.%D0%97%D0%B0%D0%BA%D0%B0%D0%B7/%D0%9F%D0%BE%D0%BB%D0%B5%2F%D0%A1%D1%83%D0%BC%D0%BC%D0%B0");
КонецПроцедуры

#КонецОбласти
