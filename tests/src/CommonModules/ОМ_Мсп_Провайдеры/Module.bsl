#Область ПрограммныйИнтерфейс

// Регистрирует сценарии тестового модуля.
Процедура ИсполняемыеСценарии() Экспорт
	ЮТТесты.ДобавитьТест("ТестАвтопоискИнструментов");
	ЮТТесты.ДобавитьТест("ТестВызовИнструментаСложение");
	ЮТТесты.ДобавитьТест("ТестВызовИнструментаВычитание");
КонецПроцедуры

// Проверяет автопоиск инструментов по подсистеме.
Процедура ТестАвтопоискИнструментов() Экспорт
	ПодготовитьИнструменты();

	Реестр = Мсп_РеестрКлиент.ПолучитьРеестр("Инструменты");
	ЮТест.ОжидаетЧто(Реестр.СодержитКлюч("infobase.info")).ЭтоИстина("Ожидается infobase.info");
	ЮТест.ОжидаетЧто(Реестр.СодержитКлюч("math.add")).ЭтоИстина("Ожидается math.add");
	ЮТест.ОжидаетЧто(Реестр.СодержитКлюч("math.sub")).ЭтоИстина("Ожидается math.sub");
КонецПроцедуры

// Проверяет синхронный вызов math.add.
Процедура ТестВызовИнструментаСложение() Экспорт
	ПодготовитьИнструменты();

	Ответ = ВызватьИнструмент("math.add", Новый Структура("a,b", 2, 3));
	Данные = ПолучитьДанныеОтвета(Ответ);
	Если Данные = Неопределено Тогда
		ЮТест.Упал("Ответ инструмента math.add не сформирован");
		Возврат;
	КонецЕсли;

	Сумма = Мсп_ИнструментыКлиент.ПолучитьСвойство(Данные, "sum", Неопределено);
	ЮТест.ОжидаетЧто(Сумма).Равно(5, "Проверка суммы");
КонецПроцедуры

// Проверяет синхронный вызов math.sub.
Процедура ТестВызовИнструментаВычитание() Экспорт
	ПодготовитьИнструменты();

	Ответ = ВызватьИнструмент("math.sub", Новый Структура("a,b", 5, 2));
	Данные = ПолучитьДанныеОтвета(Ответ);
	Если Данные = Неопределено Тогда
		ЮТест.Упал("Ответ инструмента math.sub не сформирован");
		Возврат;
	КонецЕсли;

	Разность = Мсп_ИнструментыКлиент.ПолучитьСвойство(Данные, "sub", Неопределено);
	ЮТест.ОжидаетЧто(Разность).Равно(3, "Проверка разности");
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ПодготовитьИнструменты()
	Мсп_ИнструментыКлиент.ИнициализироватьРеестры();
	Реестр = Мсп_РеестрКлиент.ПолучитьРеестр("Инструменты");
	Реестр.Очистить();
	Мсп_ПровайдерыКлиент.ЗарегистрироватьПровайдеров();
КонецПроцедуры

Функция ВызватьИнструмент(ИмяИнструмента, Аргументы)
	Параметры = Новый Структура("name,arguments", ИмяИнструмента, Аргументы);
	Сообщение = Новый Структура("jsonrpc,id,method,params", "2.0", "1", "tools/call", Параметры);
	Возврат Мсп_ПротоколКлиент.ОбработатьJSONRPC(Сообщение, "test-session");
КонецФункции

Функция ПолучитьДанныеОтвета(Ответ)
	Если Ответ = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;

	Результат = Мсп_ИнструментыКлиент.ПолучитьСвойство(Ответ, "result", Неопределено);
	Если Результат = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;

	Контент = Мсп_ИнструментыКлиент.ПолучитьСвойство(Результат, "content", Неопределено);
	Если ТипЗнч(Контент) <> Тип("Массив") Тогда
		Возврат Неопределено;
	КонецЕсли;
	Если Контент.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;

	Элемент = Контент[0];
	Текст = Мсп_ИнструментыКлиент.ПолучитьСвойство(Элемент, "text", "");
	Если Не ЗначениеЗаполнено(Текст) Тогда
		Возврат Неопределено;
	КонецЕсли;

	Возврат Мсп_ПротоколКлиент.ПрочитатьJSONСтроку(Текст);
КонецФункции

#КонецОбласти
