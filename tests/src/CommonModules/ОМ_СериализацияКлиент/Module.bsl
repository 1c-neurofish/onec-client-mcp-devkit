#Область ПрограммныйИнтерфейс

// Регистрирует сценарии тестового модуля.
Процедура ИсполняемыеСценарии() Экспорт
	ЮТТесты
		.ДобавитьТест("ПрочитатьJSONСтрокуВозвращаетСоответствие")
		.ДобавитьТест("ПрочитатьJSONСтрокуВозвращаетЗначениеПоля")
		.ДобавитьТест("ПрочитатьJSONСтрокуВозвращаетМассив")
		.ДобавитьТест("ПрочитатьJSONСтрокуНеверныйJSONВызываетИсключение")
		.ДобавитьТест("ПрочитатьJSONСтрокуБезОшибокВозвращаетОбъект")
		.ДобавитьТест("ПрочитатьJSONСтрокуБезОшибокНеверныйJSONВозвращаетУмолчание")
		.ДобавитьТест("ПрочитатьJSONСтрокуБезОшибокБезУмолчанияВозвращаетНеопределено")
		.ДобавитьТест("СериализоватьВозвращаетJSONСтроку")
		.ДобавитьТест("СериализоватьРаундТрип");
КонецПроцедуры

// Проверяет, что ПрочитатьJSONСтроку возвращает Соответствие для JSON-объекта.
Процедура ПрочитатьJSONСтрокуВозвращаетСоответствие() Экспорт
	Результат = Мсп_СериализацияКлиент.ПрочитатьJSONСтроку("{""ключ"":""значение""}");

	ЮТест.ОжидаетЧто(ТипЗнч(Результат)).Равно(Тип("Соответствие"));
КонецПроцедуры

// Проверяет, что ПрочитатьJSONСтроку возвращает корректное значение поля.
Процедура ПрочитатьJSONСтрокуВозвращаетЗначениеПоля() Экспорт
	Результат = Мсп_СериализацияКлиент.ПрочитатьJSONСтроку("{""имя"":""тест""}");

	ЮТест.ОжидаетЧто(Результат.Получить("имя")).Равно("тест");
КонецПроцедуры

// Проверяет чтение JSON-массива.
Процедура ПрочитатьJSONСтрокуВозвращаетМассив() Экспорт
	Результат = Мсп_СериализацияКлиент.ПрочитатьJSONСтроку("[1,2,3]");

	ЮТест.ОжидаетЧто(ТипЗнч(Результат)).Равно(Тип("Массив"));
	ЮТест.ОжидаетЧто(Результат.Количество()).Равно(3);
КонецПроцедуры

// Проверяет, что ПрочитатьJSONСтроку вызывает исключение при неверном JSON.
Процедура ПрочитатьJSONСтрокуНеверныйJSONВызываетИсключение() Экспорт
	ЕстьИсключение = Ложь;

	Попытка
		Мсп_СериализацияКлиент.ПрочитатьJSONСтроку("не json");
	Исключение
		ЕстьИсключение = Истина;
	КонецПопытки;

	ЮТест.ОжидаетЧто(ЕстьИсключение).ЭтоИстина();
КонецПроцедуры

// Проверяет, что ПрочитатьJSONСтрокуБезОшибок возвращает корректный объект.
Процедура ПрочитатьJSONСтрокуБезОшибокВозвращаетОбъект() Экспорт
	Результат = Мсп_СериализацияКлиент.ПрочитатьJSONСтрокуБезОшибок("{""имя"":""тест""}", Неопределено);

	ЮТест.ОжидаетЧто(Результат.Получить("имя")).Равно("тест");
КонецПроцедуры

// Проверяет, что ПрочитатьJSONСтрокуБезОшибок возвращает значение по умолчанию при неверном JSON.
Процедура ПрочитатьJSONСтрокуБезОшибокНеверныйJSONВозвращаетУмолчание() Экспорт
	Результат = Мсп_СериализацияКлиент.ПрочитатьJSONСтрокуБезОшибок("не json", "умолчание");

	ЮТест.ОжидаетЧто(Результат).Равно("умолчание");
КонецПроцедуры

// Проверяет, что ПрочитатьJSONСтрокуБезОшибок без умолчания возвращает Неопределено при ошибке.
Процедура ПрочитатьJSONСтрокуБезОшибокБезУмолчанияВозвращаетНеопределено() Экспорт
	Результат = Мсп_СериализацияКлиент.ПрочитатьJSONСтрокуБезОшибок("не json");

	ЮТест.ОжидаетЧто(Результат).НеЗаполнено();
КонецПроцедуры

// Проверяет, что Сериализовать возвращает строку содержащую ключ и значение.
Процедура СериализоватьВозвращаетJSONСтроку() Экспорт
	Данные = Новый Структура("ключ", "значение");

	Результат = Мсп_СериализацияКлиент.Сериализовать(Данные);

	ЮТест.ОжидаетЧто(ТипЗнч(Результат)).Равно(Тип("Строка"));
	ЮТест.ОжидаетЧто(Результат).Содержит("ключ");
	ЮТест.ОжидаетЧто(Результат).Содержит("значение");
КонецПроцедуры

// Проверяет, что Сериализовать + ПрочитатьJSONСтроку сохраняет значения полей.
Процедура СериализоватьРаундТрип() Экспорт
	Данные = Новый Структура("имя,число", "тест", 42);

	JSON = Мсп_СериализацияКлиент.Сериализовать(Данные);
	Прочитано = Мсп_СериализацияКлиент.ПрочитатьJSONСтроку(JSON);

	ЮТест.ОжидаетЧто(Прочитано.Получить("имя")).Равно("тест");
	ЮТест.ОжидаетЧто(Прочитано.Получить("число")).Равно(42);
КонецПроцедуры

#КонецОбласти
