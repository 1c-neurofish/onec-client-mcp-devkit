#Область СлужебныйПрограммныйИнтерфейс

Процедура ИсполняемыеСценарии() Экспорт

	ЮТТесты
		.ДобавитьТест("ПростыеПоляВвода_СнапшотФормы")
		.ДобавитьТест("УправляемыеЭлементы_СнапшотФормы")
		.ДобавитьТест("УправляемыеЭлементы_ВыполнитьДействие")
		.ДобавитьТест("УправляемыеЭлементы_СкрытьПоказатьПоле")
		.ДобавитьТест("ТаблицаЗначений_СнапшотФормы")
		.ДобавитьТест("ТаблицаЗначений_ЗаполнитьИОчистить")
		.ДобавитьТест("ГруппыИВкладки_СнапшотФормы")
		.ДобавитьТест("ГруппыИВкладки_ЗаполнитьПоля");

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ТестКлиент()
	Возврат Мсп_УправлениеТестКлиентом.ПолучитьТестКлиент();
КонецФункции

Функция ОткрытьФормуТестирования(ИмяФормы)
	Форма = ТестКлиент().ОткрытьФорму("Обработка.ТестированиеВвода.Форма." + ИмяФормы);
	Возврат Форма;
КонецФункции

// ПростыеПоляВвода

Процедура ПростыеПоляВвода_СнапшотФормы() Экспорт
	Форма = ОткрытьФормуТестирования("ПростыеПоляВвода");

	Форма.УстановитьЗначение("Строка", "Тестовая строка");
	Форма.УстановитьЗначение("Число", 42);
	Форма.УстановитьЗначение("Дата", '20240101');
	Форма.УстановитьЗначение("Реквизит1", "Рек1");
	Форма.УстановитьЗначение("Реквизит2", "Рек2");
	Форма.УстановитьЗначение("Реквизит3", "Рек3");
	Форма.УстановитьЗначение("Реквизит4", "Рек4");
	Форма.УстановитьЗначение("Реквизит5", "Рек5");
	Форма.УстановитьЗначение("Реквизит6", "Рек6");

	Снапшот = Форма.ПолучитьСнимок();

	ЮТест.ОжидаетЧто(Снапшот).НеРавно(Неопределено);
	ЮТест.ОжидаетЧто(Форма.ПолучитьЗначение("Строка")).Равно("Тестовая строка");
	ЮТест.ОжидаетЧто(Форма.ПолучитьЗначение("Число")).Равно(42);

	Форма.Закрыть();
КонецПроцедуры

// УправляемыеЭлементы

Процедура УправляемыеЭлементы_СнапшотФормы() Экспорт
	Форма = ОткрытьФормуТестирования("УправляемыеЭлементы");

	Форма.УстановитьЗначение("Флажок", Истина);
	Форма.УстановитьЗначение("ПереключательА", Истина);
	Форма.УстановитьЗначение("ПереключательБ", Ложь);
	Форма.УстановитьЗначение("ПереключательВ", Ложь);
	Форма.УстановитьЗначение("СписокВыбора", "Значение1");
	Форма.УстановитьЗначение("СкрываемоеПоле", "Видимое значение");

	Снапшот = Форма.ПолучитьСнимок();

	ЮТест.ОжидаетЧто(Снапшот).НеРавно(Неопределено);
	ЮТест.ОжидаетЧто(Форма.ПолучитьЗначение("Флажок")).Равно(Истина);
	ЮТест.ОжидаетЧто(Форма.ПолучитьЗначение("СписокВыбора")).Равно("Значение1");

	Форма.Закрыть();
КонецПроцедуры

Процедура УправляемыеЭлементы_ВыполнитьДействие() Экспорт
	Форма = ОткрытьФормуТестирования("УправляемыеЭлементы");

	Форма.НажатьКнопку("КнопкаВыполнитьДействие");

	ЮТест.ОжидаетЧто(Форма.ПолучитьЗначение("ТекстРезультата")).Равно("Кнопка нажата");

	Форма.Закрыть();
КонецПроцедуры

Процедура УправляемыеЭлементы_СкрытьПоказатьПоле() Экспорт
	Форма = ОткрытьФормуТестирования("УправляемыеЭлементы");

	ВидимостьДо = Форма.ПолучитьСвойство("СкрываемоеПоле", "Видимость");
	Форма.НажатьКнопку("КнопкаСкрытьПоказать");
	ВидимостьПосле = Форма.ПолучитьСвойство("СкрываемоеПоле", "Видимость");

	ЮТест.ОжидаетЧто(ВидимостьПосле).НеРавно(ВидимостьДо);

	Форма.Закрыть();
КонецПроцедуры

