Процедура ГруппыИВкладки_ЗаполнитьПоля() Экспорт
	Форма = ОткрытьФормуТестирования("ГруппыИВкладки");

	Форма.УстановитьЗначение("Поле1", "Значение1");
	Форма.УстановитьЗначение("Поле2", 99);
	Форма.УстановитьЗначение("Поле3", '20240601');
	Форма.УстановитьЗначение("Поле4", Истина);
	Форма.УстановитьЗначение("ПолеВГруппе", "ВГруппе");

	Снапшот = Форма.ПолучитьСнимок();

	ЮТест.ОжидаетЧто(Снапшот).НеРавно(Неопределено);
	ЮТест.ОжидаетЧто(Форма.ПолучитьЗначение("Поле1")).Равно("Значение1");
	ЮТест.ОжидаетЧто(Форма.ПолучитьЗначение("Поле2")).Равно(99);
	ЮТест.ОжидаетЧто(Форма.ПолучитьЗначение("Поле4")).Равно(Истина);
	ЮТест.ОжидаетЧто(Форма.ПолучитьЗначение("ПолеВГруппе")).Равно("ВГруппе");

	Форма.Закрыть();
КонецПроцедуры

