Процедура ТаблицаЗначений_ЗаполнитьИОчистить() Экспорт
	Форма = ОткрытьФормуТестирования("ТаблицаЗначений");

	Форма.НажатьКнопку("КнопкаЗаполнить");
	КоличествоПослеЗаполнения = Форма.ПолучитьКоличествоСтрок("Таблица");
	ЮТест.ОжидаетЧто(КоличествоПослеЗаполнения).Равно(3);

	Форма.НажатьКнопку("КнопкаОчистить");
	КоличествоПослеОчистки = Форма.ПолучитьКоличествоСтрок("Таблица");
	ЮТест.ОжидаетЧто(КоличествоПослеОчистки).Равно(0);

	Форма.Закрыть();
КонецПроцедуры

