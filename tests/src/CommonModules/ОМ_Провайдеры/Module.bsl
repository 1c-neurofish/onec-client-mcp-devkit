// Проверяет синхронный вызов math_add.
Процедура ВызовИнструментаСложение() Экспорт
	ПодготовитьИнструменты();

	Ответ = ВызватьИнструмент("math_add", Новый Структура("a,b", 2, 3));
	Данные = ПолучитьДанныеОтвета(Ответ);
	Если Данные = Неопределено Тогда
		ЮТест.Упал("Ответ инструмента math_add не сформирован");
		Возврат;
	КонецЕсли;

	Сумма = Мсп_ИнструментыКлиент.ПолучитьСвойство(Данные, "sum", Неопределено);
	ЮТест.ОжидаетЧто(Сумма)
		.Равно(5, "Проверка суммы");
КонецПроцедуры

