// Регистрирует сценарии тестового модуля.
Процедура ИсполняемыеСценарии() Экспорт
	ЮТТесты.ДобавитьТест("АвтопоискИнструментов")
		.ДобавитьТест("РесурсыТестКлиентаРегистрируютсяПоНовомуКонтракту")
		.ДобавитьТест("ЧтениеРесурсаПоШаблонуПередаетКонтекст")
		.ДобавитьТест("ТочныйРесурсИмеетПриоритетНадШаблоном")
		.ДобавитьТест("ЧтениеРесурсаФормыСНекорректнымURIВозвращает32602")
		.ДобавитьТест("ЧтениеРесурсаФормыБезКлиентаВозвращаетUI_NOT_READY")
		.ДобавитьТест("ВызовИнструментаСложение")
		.ДобавитьТест("ВызовИнструментаВычитание")
		.ДобавитьТест("ВызовИнструментаПоискБезКлиента")
		.ДобавитьТест("ВызовИнструментаПоискСНекорректнымТаймаутом")
		.ДобавитьТест("ВызовИнструментаАктивацияСНекорректнымURI")
		.ДобавитьТест("ВызовИнструментаЗакрытиеControlОтклоняется")
		.ДобавитьТест("ВызовИнструментаОткрытиеФормыБезКлиента")
		.ДобавитьТест("ВызовИнструментаОткрытиеФормыСНекорректнымTarget");
КонецПроцедуры

// Проверяет автопоиск инструментов по подсистеме.
Процедура АвтопоискИнструментов() Экспорт
	ПодготовитьИнструменты();

	Реестр = Мсп_РеестрКлиент.ПолучитьРеестр("Инструменты");
	ЮТест.ОжидаетЧто(Реестр)
		.Свойство("infobase_info")
		.Свойство("math_add")
		.Свойство("math_sub")
		.Свойство("test_client_start")
		.Свойство("test_client_stop")
		.Свойство("find")
		.Свойство("activate")
		.Свойство("close")
		.Свойство("open_form")
		;
КонецПроцедуры

// Проверяет публикацию ресурсов тест-клиента по новому контракту.
Процедура РесурсыТестКлиентаРегистрируютсяПоНовомуКонтракту() Экспорт
	ПодготовитьРесурсы();

	ЮТест.ОжидаетЧто(Мсп_РеестрКлиент.РеестрРесурсов())
		.Свойство("window://active");
	ЮТест.ОжидаетЧто(Мсп_РеестрКлиент.РеестрШаблоновРесурсов())
		.Свойство("window://{path}")
		.Свойство("form://{name}");
КонецПроцедуры

// Проверяет передачу uriTemplate и arguments в обработчик template-ресурса.
Процедура ЧтениеРесурсаПоШаблонуПередаетКонтекст() Экспорт
	ПодготовитьПустыеРесурсы();
	Мсп_РеестрКлиент.ЗарегистрироватьШаблонРесурса(НовыйОписаниеШаблонаРесурса(
		"test://{id}",
		"Тестовый шаблон",
		"Проверка template-ресурса",
		Новый ОписаниеОповещения("ОбработатьТестовыйШаблонРесурса", ОМ_Провайдеры)));

	Параметры = Новый Структура("uri,uriTemplate,arguments", "test://42", "test://{id}", Новый Структура("id", "42"));
	Ответ = Мсп_ПротоколКлиент.ПрочитатьРесурс("1", Параметры, "test-session");
	Контент = ПолучитьКонтентРесурса(Ответ);
	Данные = Мсп_ПротоколКлиент.ПрочитатьJSONСтроку(Мсп_ИнструментыКлиент.ПолучитьСвойство(Контент, "text", ""));

	ЮТест.ОжидаетЧто(Контент)
		.Свойство("uri").Равно("test://42");
	ЮТест.ОжидаетЧто(Данные)
		.Свойство("uri").Равно("test://42")
		.Свойство("uriTemplate").Равно("test://{id}")
		.Свойство("argumentId").Равно("42");
КонецПроцедуры

// Проверяет приоритет точного ресурса над шаблоном при разрешении дескриптора.
