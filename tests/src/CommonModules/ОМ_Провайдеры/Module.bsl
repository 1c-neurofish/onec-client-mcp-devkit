	ПодготовитьПустыеРесурсы();
	Мсп_РеестрКлиент.ЗарегистрироватьРесурс(НовыйОписаниеРесурса(
		"test://42",
		"Точный ресурс",
		"Проверка приоритета точного ресурса",
		Новый ОписаниеОповещения("ОбработатьТочныйТестовыйРесурс", ОМ_Провайдеры)));
	Мсп_РеестрКлиент.ЗарегистрироватьШаблонРесурса(НовыйОписаниеШаблонаРесурса(
		"test://{id}",
		"Тестовый шаблон",
		"Проверка приоритета точного ресурса",
		Новый ОписаниеОповещения("ОбработатьТестовыйШаблонРесурса", ОМ_Провайдеры)));

	Параметры = Новый Структура("uri,uriTemplate,arguments", "test://42", "test://{id}", Новый Структура("id", "42"));
	Ответ = Мсп_ПротоколКлиент.ПрочитатьРесурс("1", Параметры, "test-session");
	Контент = ПолучитьКонтентРесурса(Ответ);

	ЮТест.ОжидаетЧто(Мсп_ИнструментыКлиент.ПолучитьСвойство(Контент, "text", "")).Равно("exact");
КонецПроцедуры

// Проверяет маппинг некорректного URI ресурса формы в -32602.
