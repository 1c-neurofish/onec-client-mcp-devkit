	Параметры = Новый Структура("uri,uriTemplate,arguments", "form://", "form://{name}", Новый Структура);
	Ответ = Мсп_ПротоколКлиент.ПрочитатьРесурс("1", Параметры, "test-session");
	Ошибка = ПолучитьОшибкуОтвета(Ответ);

	ЮТест.ОжидаетЧто(Ошибка)
		.Свойство("code").Равно(-32602)
		.Свойство("message").Равно("INVALID_URI: form uri segment is empty");
КонецПроцедуры

// Проверяет ошибку чтения формы без подключенного тест-клиента.
