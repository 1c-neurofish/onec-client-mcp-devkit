#Область СлужебныеПроцедурыИФункции

Процедура ПодготовитьИнструменты()
	Мсп_ИнструментыКлиент.ИнициализироватьРеестры();
	Реестр = Мсп_РеестрКлиент.ПолучитьРеестр("Инструменты");
	Реестр.Очистить();
	Мсп_ПровайдерыКлиент.ЗарегистрироватьПровайдеров();
КонецПроцедуры

Процедура ПодготовитьРесурсы()
	ПодготовитьПустыеРесурсы();
	Мсп_ПровайдерыКлиент.ЗарегистрироватьПровайдеров();
КонецПроцедуры

Процедура ПодготовитьПустыеРесурсы()
	Мсп_РеестрКлиент.ИнициализироватьРеестры();
	Мсп_РеестрКлиент.РеестрРесурсов().Очистить();
	Мсп_РеестрКлиент.РеестрШаблоновРесурсов().Очистить();
КонецПроцедуры

Процедура ПодготовитьСостояниеТестКлиента()
	Мсп_СостояниеКлиент.УстановитьСостояниеЗначение(
		"ПараметрыЛогирования",
		Новый Структура("Логировать,УровеньЛога,ФайлЛога", Ложь, "error", ""));
	Мсп_СостояниеКлиент.УстановитьСостояниеЗначение("ПамятьТестКлиент", Новый Структура);
КонецПроцедуры

Функция ВызватьИнструмент(ИмяИнструмента, Аргументы)
	Параметры = Новый Структура("name,arguments", ИмяИнструмента, Аргументы);
	Сообщение = Новый Структура("jsonrpc,id,method,params", "2.0", "1", "tools/call", Параметры);
	Возврат Мсп_ПротоколКлиент.ОбработатьJSONRPC(Сообщение, "test-session");
КонецФункции

Функция ПолучитьДанныеОтвета(Ответ)
	Если Ответ = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;

	Результат = Мсп_ИнструментыКлиент.ПолучитьСвойство(Ответ, "result", Неопределено);
	Если Результат = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;

	Контент = Мсп_ИнструментыКлиент.ПолучитьСвойство(Результат, "content", Неопределено);
	Если ТипЗнч(Контент) <> Тип("Массив") Тогда
		Возврат Неопределено;
	КонецЕсли;
	Если Контент.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;

	Элемент = Контент[0];
	Текст = Мсп_ИнструментыКлиент.ПолучитьСвойство(Элемент, "text", "");
	Если Не ЗначениеЗаполнено(Текст) Тогда
		Возврат Неопределено;
	КонецЕсли;

	Возврат Мсп_ПротоколКлиент.ПрочитатьJSONСтроку(Текст);
КонецФункции

Функция ПолучитьКонтентРесурса(Ответ)
	Если Ответ = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;

	Результат = Мсп_ИнструментыКлиент.ПолучитьСвойство(Ответ, "result", Неопределено);
	Если Результат = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;

	Контент = Мсп_ИнструментыКлиент.ПолучитьСвойство(Результат, "contents", Неопределено);
	Если ТипЗнч(Контент) <> Тип("Массив")
		ИЛИ Контент.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;

	Возврат Контент[0];
КонецФункции

Функция ПолучитьОшибкуОтвета(Ответ)
	Если Ответ = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;

	Возврат Мсп_ИнструментыКлиент.ПолучитьСвойство(Ответ, "error", Неопределено);
КонецФункции

Функция НовыйОписаниеРесурса(URI, Имя, Описание, Обработчик)
	ОписаниеРесурса = Мсп_РеестрКлиент.НовыйОписаниеРесурса();
	ОписаниеРесурса.URI = URI;
	ОписаниеРесурса.Имя = Имя;
	ОписаниеРесурса.Описание = Описание;
	ОписаниеРесурса.MimeType = "application/json";
	ОписаниеРесурса.Обработчик = Обработчик;
	Возврат ОписаниеРесурса;
КонецФункции

Функция НовыйОписаниеШаблонаРесурса(URIШаблон, Имя, Описание, Обработчик)
	ОписаниеШаблонаРесурса = Мсп_РеестрКлиент.НовыйОписаниеШаблонаРесурса();
	ОписаниеШаблонаРесурса.URIШаблон = URIШаблон;
	ОписаниеШаблонаРесурса.Имя = Имя;
	ОписаниеШаблонаРесурса.Описание = Описание;
	ОписаниеШаблонаРесурса.MimeType = "application/json";
	ОписаниеШаблонаРесурса.Обработчик = Обработчик;
	Возврат ОписаниеШаблонаРесурса;
КонецФункции

Функция ОбработатьТестовыйШаблонРесурса(Запрос, ДополнительныеПараметры) Экспорт
	Аргументы = Мсп_ИнструментыКлиент.ПолучитьСвойство(Запрос.Контекст, "arguments", Новый Структура);
	Данные = Новый Структура(
		"uri,uriTemplate,argumentId",
		Мсп_ИнструментыКлиент.ПолучитьСвойство(Запрос.Контекст, "uri", ""),
		Мсп_ИнструментыКлиент.ПолучитьСвойство(Запрос.Контекст, "uriTemplate", ""),
		Мсп_ИнструментыКлиент.ПолучитьСвойство(Аргументы, "id", ""));
	Возврат Мсп_СериализацияКлиент.Сериализовать(Данные);
КонецФункции

Функция ОбработатьТочныйТестовыйРесурс(Запрос, ДополнительныеПараметры) Экспорт
	Возврат "exact";
КонецФункции

