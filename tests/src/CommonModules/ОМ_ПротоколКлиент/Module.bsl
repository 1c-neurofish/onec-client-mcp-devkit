// Проверяет, что бизнес-структура с полем error не воспринимается как envelope ошибки.
Процедура ПодготовитьЗавершениеЗадачиИнструментаНеСчитаетБизнесСтруктуруОшибкой() Экспорт
	Подготовлено = Мсп_ПротоколКлиент.ПодготовитьЗавершениеЗадачиИнструмента(
		Мсп_Результаты.JSON(Новый Структура("error,count", Ложь, 3)));

	ЮТест.ОжидаетЧто(Подготовлено)
		.Свойство("Статус").Равно("completed");
	ЮТест.ОжидаетЧто(Подготовлено.Тело.result.content[0].text).НеРавно("");
КонецПроцедуры

Процедура ПодготовитьЗавершениеЗадачиИнструментаБизнесСтруктураСКодОшибкиОстаетсяResult() Экспорт
	БизнесРезультат = Новый Структура("КодОшибки,count", "BUSINESS_CODE", 2);
	Подготовлено = Мсп_ПротоколКлиент.ПодготовитьЗавершениеЗадачиИнструмента(БизнесРезультат);

	ЮТест.ОжидаетЧто(Подготовлено.Статус).Равно("completed");
	ЮТест.ОжидаетЧто(Подготовлено.Тело.Свойство("result")).Равно(Истина);
	ЮТест.ОжидаетЧто(Подготовлено.Тело.Свойство("error")).Равно(Ложь);
	ЮТест.ОжидаетЧто(Подготовлено.Тело.result.content[0].text).Равно(Мсп_СериализацияКлиент.Сериализовать(БизнесРезультат));
КонецПроцедуры

