#Область СлужебныеПроцедурыИФункции

Процедура ПодготовитьСостояние()
	Мсп_СостояниеКлиент.УстановитьСостояниеЗначение("Инструменты", Новый Соответствие);
	Мсп_СостояниеКлиент.УстановитьСостояниеЗначение("Ресурсы", Новый Соответствие);
	Мсп_СостояниеКлиент.УстановитьСостояниеЗначение("ШаблоныРесурсов", Новый Соответствие);
	Мсп_СостояниеКлиент.УстановитьСостояниеЗначение("Промпты", Новый Соответствие);
КонецПроцедуры

Процедура ЗарегистрироватьТестовыйИнструмент(Имя, ИмяОбработчика)
	Описание = Мсп_РеестрКлиент.НовыйОписаниеИнструмента();
	Описание.Имя = Имя;
	Описание.Обработчик = Новый ОписаниеОповещения(ИмяОбработчика, ЭтотОбъект);
	Мсп_РеестрКлиент.ЗарегистрироватьИнструмент(Описание);
КонецПроцедуры

Функция ОбработчикИнструмента(Запрос, ДополнительныеПараметры)
	Возврат "результат";
КонецФункции

Функция ОбработчикРесурса(Запрос, ДополнительныеПараметры)
	Возврат Новый Структура("contents", Новый Массив);
КонецФункции

Функция ОбработчикПромпта(Запрос, ДополнительныеПараметры)
	Возврат Новый Структура("messages", Новый Массив);
КонецФункции

#КонецОбласти
