Функция ОбработатьТочныйТестовыйРесурс(Запрос, ДополнительныеПараметры) Экспорт
	Возврат Мсп_Результаты.Ресурс(
		Мсп_Коллекции.Свойство(Запрос.Контекст, "uri", ""),
		"exact",
		"text/plain");
КонецФункции

Процедура СохранитьПоследнийЗапросИнструмента(Запрос)
	Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера(
		"ОМ_ПротоколКлиентПоследнийЗапросИнструмента",
		Запрос);
КонецПроцедуры

Функция ПолучитьПоследнийЗапросИнструмента()
	Возврат Мсп_СостояниеКлиент.ЗначениеСостоянияСервера(
		"ОМ_ПротоколКлиентПоследнийЗапросИнструмента",
		Неопределено);
КонецФункции

