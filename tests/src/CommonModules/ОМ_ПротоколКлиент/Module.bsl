// Проверяет, что НовыйОписаниеИнструмента заполняет поля name, description, inputSchema.
Процедура НовыйОписаниеИнструментаЗаполняетПоля() Экспорт
	Схема = Новый Структура("type", "object");

	Описание = Мсп_ПротоколКлиент.НовыйОписаниеИнструмента("мой_инструмент", "Описание", Схема);

	ЮТест.ОжидаетЧто(Описание)
		.Свойство("name").Равно("мой_инструмент")
		.Свойство("description").Равно("Описание")
		.Свойство("inputSchema").Равно(Схема);
КонецПроцедуры

// Проверяет, что task-инструмент публикует execution.taskSupport.
Процедура НовыйОписаниеИнструментаДляTaskИнструментаДобавляетExecution() Экспорт
	Схема = Новый Структура("type", "object");

	Описание = Мсп_ПротоколКлиент.НовыйОписаниеИнструмента("мой_инструмент", "Описание", Схема, "task");

	ЮТест.ОжидаетЧто(Описание.Свойство("execution")).Равно(Истина);
	ЮТест.ОжидаетЧто(Описание.execution.taskSupport).Равно("optional");
КонецПроцедуры

// Проверяет единый служебный контракт вызова инструмента.
Процедура НовыйВызовИнструментаЗаполняетКонтракт() Экспорт
	ВызовИнструмента = Мсп_ПротоколКлиент.НовыйВызовИнструмента(
		"request-1",
		"async_tool",
		Новый Структура("ticks", 3),
		"test-session",
		"task",
		"task-123",
		"progress-123");

	ЮТест.ОжидаетЧто(ВызовИнструмента)
		.Свойство("Идентификатор").Равно("request-1")
		.Свойство("ИмяИнструмента").Равно("async_tool")
		.Свойство("Сессия").Равно("test-session")
		.Свойство("РежимВыполнения").Равно("task")
		.Свойство("ИдентификаторЗадачи").Равно("task-123")
		.Свойство("ProgressToken").Равно("progress-123");
	ЮТест.ОжидаетЧто(ВызовИнструмента.Аргументы.ticks).Равно(3);
КонецПроцедуры

// Проверяет, что пропущенные аргументы заменяются пустой структурой.
Процедура НовыйВызовИнструментаБезАргументовСоздаетПустуюСтруктуру() Экспорт
	ВызовИнструмента = Мсп_ПротоколКлиент.НовыйВызовИнструмента("request-2", "infobase_info");

	ЮТест.ОжидаетЧто(ТипЗнч(ВызовИнструмента.Аргументы)).Равно(Тип("Структура"));
	ЮТест.ОжидаетЧто(ВызовИнструмента.Аргументы.Количество()).Равно(0);
КонецПроцедуры

// Проверяет, что внутренний запрос вызова создается через единый контракт.
Процедура НовыйЗапросВызоваЗаполняетКонтракт() Экспорт
	Аргументы = Новый Структура("ticks", 3);
	Контекст = Новый Структура("kind,requestId", "tools", "request-1");

	Запрос = Мсп_ПротоколКлиент.НовыйЗапросВызова(Аргументы, Контекст, "task-123");

	ЮТест.ОжидаетЧто(Запрос)
		.Свойство("Аргументы").Равно(Аргументы)
		.Свойство("Контекст").Равно(Контекст)
		.Свойство("Идентификатор").Равно("request-1")
		.Свойство("ИдентификаторЗадачи").Равно("task-123");
КонецПроцедуры

// Проверяет, что параметры завершения задачи создаются через единый контракт.
Процедура НовыйПараметрыЗавершенияЗадачиЗаполняетКонтракт() Экспорт
	Тело = Новый Структура("result", Новый Структура("content", Новый Массив));

	ПараметрыЗавершения = Мсп_ПротоколКлиент.НовыйПараметрыЗавершенияЗадачи(
		"completed",
		"",
		Тело);

	ЮТест.ОжидаетЧто(ПараметрыЗавершения)
		.Свойство("Статус").Равно("completed")
		.Свойство("Сообщение").Равно("")
		.Свойство("Тело").Равно(Тело);
КонецПроцедуры

// Проверяет, что успешный результат задачи нормализуется в result.
Процедура ПодготовитьЗавершениеЗадачиИнструментаДляУспехаВозвращаетResult() Экспорт
	Подготовлено = Мсп_ПротоколКлиент.ПодготовитьЗавершениеЗадачиИнструмента(Мсп_Результаты.Текст("готово"));

	ЮТест.ОжидаетЧто(Подготовлено)
		.Свойство("Статус").Равно("completed");
	ЮТест.ОжидаетЧто(Подготовлено.Тело.result.content[0].type).Равно("text");
	ЮТест.ОжидаетЧто(Подготовлено.Тело.result.content[0].text).Равно("готово");
КонецПроцедуры

Процедура ПодготовитьЗавершениеЗадачиИнструментаДляСыройСтрокиНормализуетText() Экспорт
	Подготовлено = Мсп_ПротоколКлиент.ПодготовитьЗавершениеЗадачиИнструмента("raw");

	ЮТест.ОжидаетЧто(Подготовлено.Статус).Равно("completed");
	ЮТест.ОжидаетЧто(Подготовлено.Тело.result.content[0].type).Равно("text");
	ЮТест.ОжидаетЧто(Подготовлено.Тело.result.content[0].text).Равно("raw");
КонецПроцедуры

Процедура ПодготовитьЗавершениеЗадачиИнструментаДляСырогоJSONНормализуетJson() Экспорт
	СыройРезультат = Новый Структура("ok,count", Истина, 2);
	Подготовлено = Мсп_ПротоколКлиент.ПодготовитьЗавершениеЗадачиИнструмента(СыройРезультат);

	ЮТест.ОжидаетЧто(Подготовлено.Статус).Равно("completed");
	ЮТест.ОжидаетЧто(Подготовлено.Тело.result.content[0].type).Равно("text");
	ЮТест.ОжидаетЧто(Подготовлено.Тело.result.content[0].text).Равно(Мсп_СериализацияКлиент.Сериализовать(СыройРезультат));
КонецПроцедуры

Процедура ПодготовитьЗавершениеЗадачиИнструментаДляLegacyРезультатаСохраняетКонтент() Экспорт
	LegacyРезультат = Мсп_Результаты.Текст("legacy-task");
