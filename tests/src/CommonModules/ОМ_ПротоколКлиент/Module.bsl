Функция ПолучитьКонтентРесурса(Ответ)
	Если Ответ = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;

	Результат = Мсп_Коллекции.Свойство(Ответ, "result", Неопределено);
	Если Результат = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;

	Контент = Мсп_Коллекции.Свойство(Результат, "contents", Неопределено);
	Если ТипЗнч(Контент) <> Тип("Массив")
		ИЛИ Контент.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;

	Возврат Контент[0];
КонецФункции

Функция ПолучитьОшибкуОтвета(Ответ)
	Если Ответ = Неопределено Тогда
		Возврат Неопределено;
