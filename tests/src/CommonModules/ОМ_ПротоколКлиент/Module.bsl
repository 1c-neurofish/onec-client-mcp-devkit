// Проверяет формирование обычного JSON-RPC ответа по результату инструмента.
Процедура ПодготовитьОтветЗапросаИнструментаДляУспехаВозвращаетResult() Экспорт
	Ответ = Мсп_ПротоколКлиент.ПодготовитьОтветЗапросаИнструмента("request-1", Мсп_Результаты.Текст("готово"));

	ЮТест.ОжидаетЧто(Ответ)
		.Свойство("jsonrpc").Равно("2.0")
		.Свойство("id").Равно("request-1");
	ЮТест.ОжидаетЧто(Ответ.Свойство("result")).Равно(Истина);
	ЮТест.ОжидаетЧто(Ответ.Свойство("error")).Равно(Ложь);
	ЮТест.ОжидаетЧто(Ответ.result.content[0].type).Равно("text");
	ЮТест.ОжидаетЧто(Ответ.result.content[0].text).Равно("готово");
